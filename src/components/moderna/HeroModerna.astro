---
/**
 * PLANTILLA MODERNA - Hero Section
 * Diseño bold con colores vibrantes, asimétrico, con mucho impacto visual.
 */
import { siteConfig } from '../../config/siteConfig';
import Icon from '../Icon.astro';

const { doctor, contacto, cta } = siteConfig;
const whatsappLink = `https://wa.me/${contacto.whatsapp}?text=${encodeURIComponent(cta.whatsappMensaje)}`;
---

<section id="inicio" class="relative min-h-screen flex items-center overflow-hidden" style={`background-color: var(--color-primario)`}>
  <!-- Patrón de fondo -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-0 left-0 w-full h-full" 
      style="background-image: radial-gradient(circle at 25% 25%, rgba(255,255,255,0.15) 1px, transparent 1px); background-size: 50px 50px;">
    </div>
  </div>
  
  <!-- Forma decorativa -->
  <div class="absolute right-0 top-0 w-1/2 h-full hidden lg:block">
    <div class="absolute inset-0 bg-white/5 clip-diagonal"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Contenido -->
      <div class="text-white animate-fade-in">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm rounded-full text-sm font-medium mb-8 border border-white/20">
          <div class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></div>
          <span>Aceptando nuevos pacientes</span>
        </div>

        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-tight mb-6">
          {doctor.titulo}
          <span class="block" style={`color: var(--color-secundario)`}>{doctor.nombre.split(' ')[0]}</span>
          <span class="block text-white/80">{doctor.nombre.split(' ').slice(1).join(' ')}</span>
        </h1>

        <p class="text-xl text-white/70 mb-4">
          {doctor.especialidad}
          {doctor.subespecialidad && ` · ${doctor.subespecialidad}`}
        </p>

        <p class="text-lg text-white/50 mb-8 max-w-lg">
          "{doctor.frase}"
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 font-bold rounded-full transition-all duration-300 hover:shadow-xl hover:scale-105 text-white"
            style={`background-color: var(--color-secundario)`}
          >
            {cta.principal}
            <Icon name="arrow-right" size={18} />
          </a>
          <a
            href="#servicios"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-white/30 text-white font-semibold rounded-full transition-all duration-300 hover:bg-white/10"
          >
            {cta.secundario}
          </a>
        </div>
      </div>

      <!-- Imagen circular moderna -->
      <div class="relative animate-slide-left hidden lg:flex justify-center">
        <div class="relative">
          <!-- Círculo de fondo -->
          <div class="absolute inset-0 rounded-full scale-110 opacity-20" style={`background-color: var(--color-secundario)`}></div>
          
          <div class="w-[450px] h-[450px] rounded-full overflow-hidden border-4 border-white/20 shadow-2xl">
            <img
              src={doctor.foto}
              alt={`${doctor.titulo} ${doctor.nombre}`}
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>

          <!-- Badge flotante -->
          <div class="absolute -right-4 top-1/4 bg-white rounded-2xl shadow-xl p-4">
            <div class="flex items-center gap-2">
              <Icon name="star-filled" size={20} class="text-yellow-400" />
              <span class="font-bold text-gray-900 text-lg">5.0</span>
            </div>
            <p class="text-xs text-gray-500">Calificación</p>
          </div>

          <!-- Badge flotante 2 -->
          <div class="absolute -left-4 bottom-1/4 bg-white rounded-2xl shadow-xl p-4">
            <div class="flex items-center gap-2">
              <Icon name="award" size={20} style={`color: var(--color-secundario)`} />
              <span class="font-bold text-gray-900">Certificado</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .clip-diagonal {
    clip-path: polygon(30% 0, 100% 0, 100% 100%, 0 100%);
  }
</style>
