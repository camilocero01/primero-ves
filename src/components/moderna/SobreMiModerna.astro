---
import { siteConfig } from '../../config/siteConfig';
import Icon from '../Icon.astro';

const { doctor } = siteConfig;
---

<section id="sobre-mi" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Imagen con marco moderno -->
      <div class="relative order-2 lg:order-1">
        <div class="relative rounded-3xl overflow-hidden">
          <img
            src={doctor.foto}
            alt={`${doctor.titulo} ${doctor.nombre}`}
            class="w-full h-[550px] object-cover"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
        </div>
        <!-- Counter cards -->
        <div class="absolute -bottom-6 left-6 right-6 flex gap-4">
          <div class="flex-1 bg-white rounded-2xl shadow-xl p-5 text-center">
            <p class="text-3xl font-bold" style={`color: var(--color-primario)`}>15+</p>
            <p class="text-xs text-gray-500 mt-1">Años Exp.</p>
          </div>
          <div class="flex-1 bg-white rounded-2xl shadow-xl p-5 text-center">
            <p class="text-3xl font-bold" style={`color: var(--color-secundario)`}>5K+</p>
            <p class="text-xs text-gray-500 mt-1">Pacientes</p>
          </div>
          <div class="flex-1 bg-white rounded-2xl shadow-xl p-5 text-center">
            <p class="text-3xl font-bold" style={`color: var(--color-primario)`}>5.0</p>
            <p class="text-xs text-gray-500 mt-1">Rating</p>
          </div>
        </div>
      </div>

      <!-- Contenido -->
      <div class="order-1 lg:order-2">
        <h2 class="text-4xl md:text-5xl font-bold mb-4" style={`color: var(--color-primario)`}>
          Sobre Mí
        </h2>
        <div class="w-20 h-1 rounded-full mb-8" style={`background-color: var(--color-secundario)`}></div>

        <p class="text-gray-600 text-lg leading-relaxed mb-8">
          {doctor.biografia}
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="flex items-center gap-3 p-4 bg-gray-50 rounded-2xl">
            <Icon name="check-circle" size={22} style={`color: var(--color-primario)`} />
            <span class="text-gray-700 font-medium">{doctor.especialidad}</span>
          </div>
          {doctor.subespecialidad && (
            <div class="flex items-center gap-3 p-4 bg-gray-50 rounded-2xl">
              <Icon name="check-circle" size={22} style={`color: var(--color-primario)`} />
              <span class="text-gray-700 font-medium">{doctor.subespecialidad}</span>
            </div>
          )}
          <div class="flex items-center gap-3 p-4 bg-gray-50 rounded-2xl">
            <Icon name="shield" size={22} style={`color: var(--color-secundario)`} />
            <span class="text-gray-700 font-medium">Certificado</span>
          </div>
          <div class="flex items-center gap-3 p-4 bg-gray-50 rounded-2xl">
            <Icon name="award" size={22} style={`color: var(--color-secundario)`} />
            <span class="text-gray-700 font-medium">Reconocido</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
