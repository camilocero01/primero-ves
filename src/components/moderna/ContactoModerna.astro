---
import type { DoctorConfig } from '../../config/siteConfig';
import Icon from '../Icon.astro';

interface Props { config: DoctorConfig; }
const { config } = Astro.props;
const { contacto, horarios, cta } = config;
const whatsappLink = `https://wa.me/${contacto.whatsapp}?text=${encodeURIComponent(cta.whatsappMensaje)}`;
---

<section id="contacto" class="py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4" style={`color: var(--color-primario)`}>
        Contacto
      </h2>
      <div class="w-20 h-1 mx-auto rounded-full mb-6" style={`background-color: var(--color-secundario)`}></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-12">
      <!-- Cards de contacto -->
      <a href={`tel:${contacto.telefono}`} class="group bg-white rounded-3xl p-8 text-center shadow-sm hover:shadow-xl transition-all duration-300">
        <div class="w-16 h-16 rounded-2xl mx-auto flex items-center justify-center mb-4 transition-colors group-hover:text-white" style={`background-color: var(--color-primary-light); color: var(--color-primario)`}>
          <Icon name="phone" size={28} />
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Llámanos</h3>
        <p class="text-gray-600">{contacto.telefono}</p>
      </a>

      <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="group bg-white rounded-3xl p-8 text-center shadow-sm hover:shadow-xl transition-all duration-300">
        <div class="w-16 h-16 rounded-2xl mx-auto flex items-center justify-center mb-4 bg-green-50 text-green-600 group-hover:bg-green-600 group-hover:text-white transition-colors">
          <Icon name="message-circle" size={28} />
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">WhatsApp</h3>
        <p class="text-gray-600">Mensaje directo</p>
      </a>

      <a href={`mailto:${contacto.email}`} class="group bg-white rounded-3xl p-8 text-center shadow-sm hover:shadow-xl transition-all duration-300">
        <div class="w-16 h-16 rounded-2xl mx-auto flex items-center justify-center mb-4 transition-colors group-hover:text-white" style={`background-color: var(--color-primary-light); color: var(--color-primario)`}>
          <Icon name="mail" size={28} />
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Email</h3>
        <p class="text-gray-600">{contacto.email}</p>
      </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Horarios y Ubicación -->
      <div class="bg-white rounded-3xl p-8 shadow-sm">
        <h3 class="text-2xl font-bold mb-6" style={`color: var(--color-primario)`}>
          <Icon name="calendar" size={24} class="inline mr-2" />
          Horarios
        </h3>
        <div class="space-y-4">
          {horarios.map((h) => (
            <div class="flex justify-between items-center py-3 border-b border-gray-100 last:border-0">
              <span class="font-medium text-gray-900">{h.dias}</span>
              <span class="px-4 py-1 rounded-full text-sm font-medium" style={`background-color: var(--color-primary-light); color: var(--color-primario)`}>
                {h.horas}
              </span>
            </div>
          ))}
        </div>

        <div class="mt-8 pt-6 border-t">
          <div class="flex items-start gap-3">
            <Icon name="map-pin" size={20} class="mt-1 shrink-0" style={`color: var(--color-primario)`} />
            <div>
              <p class="font-medium text-gray-900">{contacto.direccion}</p>
              <p class="text-gray-500">{contacto.ciudad}, {contacto.estado}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Mapa -->
      <div class="rounded-3xl overflow-hidden shadow-sm min-h-[400px]">
        <iframe
          src={contacto.googleMapsEmbed}
          width="100%"
          height="100%"
          style="border:0; min-height: 400px;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación del consultorio"
        ></iframe>
      </div>
    </div>
  </div>
</section>
