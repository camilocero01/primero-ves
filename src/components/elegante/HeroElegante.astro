---
/**
 * PLANTILLA ELEGANTE - Hero Section
 * Diseño sofisticado con tipografía serif y líneas limpias.
 * Ideal para médicos que buscan transmitir experiencia y confianza.
 */
import type { DoctorConfig } from '../../config/siteConfig';
import Icon from '../Icon.astro';

interface Props { config: DoctorConfig; }
const { config } = Astro.props;
const { doctor, contacto, cta, colores, imagenes } = config;
const whatsappLink = `https://wa.me/${contacto.whatsapp}?text=${encodeURIComponent(cta.whatsappMensaje)}`;
---

<section id="inicio" class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Fondo con imagen de especialidad -->
  <div class="absolute inset-0">
    <img src={imagenes.heroFondo} alt="" class="w-full h-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-r from-white via-white/95 to-white/70"></div>
  </div>
  
  <!-- Elementos decorativos -->
  <div class="absolute top-20 right-0 w-96 h-96 rounded-full opacity-5" style={`background-color: var(--color-primario)`}></div>
  <div class="absolute bottom-20 left-0 w-64 h-64 rounded-full opacity-5" style={`background-color: var(--color-secundario)`}></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Contenido -->
      <div class="animate-fade-in">
        <!-- Badge de especialidad -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium mb-8"
          style={`background-color: var(--color-secundario); color: white; opacity: 0.9`}>
          <Icon name="shield" size={16} />
          <span>{doctor.especialidad}</span>
        </div>

        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-tight mb-6" style={`color: var(--color-primario)`}>
          {doctor.titulo}<br />
          <span class="block">{doctor.nombre.split(' ').slice(0, 2).join(' ')}</span>
        </h1>

        <p class="text-xl md:text-2xl text-gray-500 font-light mb-4 italic font-heading" style={`color: var(--color-secundario)`}>
          "{doctor.frase}"
        </p>

        {doctor.subespecialidad && (
          <p class="text-gray-600 mb-8 text-lg">
            Especialista en {doctor.subespecialidad}
          </p>
        )}

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 text-white font-semibold rounded-full transition-all duration-300 hover:shadow-xl hover:scale-105"
            style={`background-color: var(--color-primario)`}
          >
            {cta.principal}
            <Icon name="arrow-right" size={18} />
          </a>
          <a
            href="#servicios"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 border-2 font-semibold rounded-full transition-all duration-300 hover:shadow-lg"
            style={`border-color: var(--color-primario); color: var(--color-primario)`}
          >
            {cta.secundario}
          </a>
        </div>

        <!-- Stats rápidos -->
        <div class="flex gap-8 mt-12 pt-8 border-t border-gray-200">
          <div>
            <p class="text-3xl font-bold" style={`color: var(--color-primario)`}>15+</p>
            <p class="text-gray-500 text-sm">Años de experiencia</p>
          </div>
          <div>
            <p class="text-3xl font-bold" style={`color: var(--color-primario)`}>5,000+</p>
            <p class="text-gray-500 text-sm">Pacientes atendidos</p>
          </div>
          <div>
            <p class="text-3xl font-bold" style={`color: var(--color-primario)`}>100%</p>
            <p class="text-gray-500 text-sm">Compromiso</p>
          </div>
        </div>
      </div>

      <!-- Imagen del doctor -->
      <div class="relative animate-slide-left hidden lg:block">
        <div class="relative w-full aspect-[3/4] rounded-2xl overflow-hidden shadow-2xl">
          <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent z-10"></div>
          <img
            src={doctor.foto}
            alt={`${doctor.titulo} ${doctor.nombre} - ${doctor.especialidad}`}
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
        <!-- Tarjeta flotante -->
        <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl shadow-xl p-6 z-20">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-full flex items-center justify-center" style={`background-color: var(--color-secundario)`}>
              <Icon name="award" size={24} class="text-white" />
            </div>
            <div>
              <p class="font-semibold text-gray-900">Certificado</p>
              <p class="text-sm text-gray-500">Consejo de Especialidad</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <Icon name="chevron-down" size={24} class="text-gray-400" />
  </div>
</section>
