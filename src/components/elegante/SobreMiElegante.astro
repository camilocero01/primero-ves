---
import { siteConfig } from '../../config/siteConfig';
import Icon from '../Icon.astro';

const { doctor } = siteConfig;
---

<section id="sobre-mi" class="py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Imagen -->
      <div class="relative">
        <div class="relative rounded-2xl overflow-hidden shadow-xl">
          <img
            src={doctor.foto}
            alt={`${doctor.titulo} ${doctor.nombre}`}
            class="w-full h-[500px] object-cover"
            loading="lazy"
          />
        </div>
        <!-- Decoración -->
        <div class="absolute -bottom-4 -right-4 w-32 h-32 rounded-2xl -z-10" style={`background-color: var(--color-secundario); opacity: 0.2`}></div>
        <div class="absolute -top-4 -left-4 w-24 h-24 rounded-2xl -z-10" style={`background-color: var(--color-primario); opacity: 0.1`}></div>
      </div>

      <!-- Contenido -->
      <div>
        <span class="text-sm font-semibold tracking-widest uppercase" style={`color: var(--color-secundario)`}>
          Conóceme
        </span>
        <h2 class="text-4xl md:text-5xl font-bold mt-3 mb-8" style={`color: var(--color-primario)`}>
          {doctor.titulo} {doctor.nombre}
        </h2>
        
        <div class="space-y-4 text-gray-600 text-lg leading-relaxed mb-8">
          <p>{doctor.biografia}</p>
        </div>

        <!-- Credenciales -->
        <div class="space-y-4">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full flex items-center justify-center" style={`background-color: var(--color-primary-light); color: var(--color-primario)`}>
              <Icon name="check-circle" size={20} />
            </div>
            <div>
              <p class="font-semibold text-gray-900">{doctor.especialidad}</p>
              {doctor.subespecialidad && <p class="text-gray-500 text-sm">{doctor.subespecialidad}</p>}
            </div>
          </div>
          {doctor.cedulaProfesional && (
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-full flex items-center justify-center" style={`background-color: var(--color-primary-light); color: var(--color-primario)`}>
                <Icon name="shield" size={20} />
              </div>
              <div>
                <p class="font-semibold text-gray-900">Cédula Profesional</p>
                <p class="text-gray-500 text-sm">{doctor.cedulaProfesional}</p>
              </div>
            </div>
          )}
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full flex items-center justify-center" style={`background-color: var(--color-primary-light); color: var(--color-primario)`}>
              <Icon name="award" size={20} />
            </div>
            <div>
              <p class="font-semibold text-gray-900">Certificación Vigente</p>
              <p class="text-gray-500 text-sm">Consejo de la Especialidad</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
