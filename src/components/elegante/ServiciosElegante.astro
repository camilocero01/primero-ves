---
import { siteConfig } from '../../config/siteConfig';
import Icon from '../Icon.astro';

const { servicios } = siteConfig;
---

<section id="servicios" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Encabezado -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-sm font-semibold tracking-widest uppercase" style={`color: var(--color-secundario)`}>
        Nuestros Servicios
      </span>
      <h2 class="text-4xl md:text-5xl font-bold mt-3 mb-6" style={`color: var(--color-primario)`}>
        Atención Especializada
      </h2>
      <p class="text-gray-600 text-lg">
        Ofrecemos una amplia gama de servicios con la más alta calidad y tecnología de vanguardia.
      </p>
    </div>

    <!-- Grid de servicios -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {servicios.map((servicio, index) => (
        <div
          class="group p-8 rounded-2xl border border-gray-100 hover:border-transparent hover:shadow-xl transition-all duration-500 bg-white"
          style={`animation-delay: ${index * 100}ms`}
        >
          <div
            class="w-14 h-14 rounded-xl flex items-center justify-center mb-6 transition-colors duration-300 group-hover:text-white"
            style={`background-color: var(--color-primary-light); color: var(--color-primario)`}
          >
            <Icon name={servicio.icono} size={28} />
          </div>
          <h3 class="text-xl font-bold mb-3 text-gray-900 group-hover:text-gray-900">
            {servicio.nombre}
          </h3>
          <p class="text-gray-600 leading-relaxed">
            {servicio.descripcion}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
