---
/**
 * PLANTILLA MINIMALISTA - Instalaciones Section
 * Slider horizontal de imágenes elegante.
 */
import type { DoctorConfig } from '../../config/siteConfig';

interface Props { config: DoctorConfig; }
const { config } = Astro.props;
const { imagenes } = config;
---

<section id="instalaciones" class="py-32 bg-gray-50">
  <div class="max-w-6xl mx-auto px-6 mb-12">
    <p class="text-xs tracking-[0.3em] uppercase text-gray-400 mb-4">Instalaciones</p>
    <h2 class="text-4xl md:text-5xl font-extralight text-gray-900 leading-tight">
      Espacios diseñados<br />
      <span class="font-normal">para tu bienestar</span>
    </h2>
  </div>

  <!-- Slider horizontal -->
  <div class="overflow-x-auto scrollbar-hide">
    <div class="flex gap-4 px-6 pb-4" style="width: max-content;">
      {imagenes.instalaciones.map((img, index) => (
        <figure 
          class="relative flex-shrink-0 w-80 md:w-96 group"
          style={`animation-delay: ${index * 100}ms`}
        >
          <div class="aspect-[4/3] overflow-hidden">
            <img 
              src={img.url} 
              alt={img.alt}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
          </div>
          <figcaption class="mt-4">
            <p class="text-gray-900 font-medium text-sm">{img.alt}</p>
            <p class="text-gray-400 text-xs mt-1">0{index + 1}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>

  <!-- Indicador de scroll -->
  <div class="max-w-6xl mx-auto px-6 mt-8">
    <div class="flex items-center gap-4 text-gray-400">
      <span class="text-xs tracking-widest uppercase">Desliza</span>
      <div class="flex-1 h-px bg-gray-200"></div>
      <span class="text-xs">{imagenes.instalaciones.length} imágenes</span>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
