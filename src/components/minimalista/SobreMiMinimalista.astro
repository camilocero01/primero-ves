---
/**
 * PLANTILLA MINIMALISTA - Sobre Mí Section
 * Diseño editorial con imagen grande y texto elegante.
 */
import type { DoctorConfig } from '../../config/siteConfig';

interface Props { config: DoctorConfig; }
const { config } = Astro.props;
const { doctor } = config;
---

<section id="sobre-mi" class="py-32 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <!-- Imagen -->
      <div class="relative">
        <div class="aspect-[4/5] overflow-hidden">
          <img 
            src={doctor.foto} 
            alt={`${doctor.titulo} ${doctor.nombre}`}
            class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
            loading="lazy"
          />
        </div>
        <!-- Frame decorativo -->
        <div class="absolute -bottom-4 -right-4 w-full h-full border border-gray-200 -z-10"></div>
      </div>

      <!-- Contenido -->
      <div class="lg:py-8">
        <p class="text-xs tracking-[0.3em] uppercase text-gray-400 mb-4">Sobre mí</p>
        
        <h2 class="text-4xl md:text-5xl font-extralight text-gray-900 leading-tight mb-8">
          {doctor.titulo}<br />
          <span class="font-normal">{doctor.nombre}</span>
        </h2>

        <div class="space-y-6 text-gray-600 font-light leading-relaxed">
          <p>{doctor.biografia}</p>
        </div>

        <!-- Credenciales -->
        <div class="mt-12 pt-8 border-t border-gray-100">
          <div class="grid grid-cols-2 gap-8">
            <div>
              <p class="text-xs tracking-[0.2em] uppercase text-gray-400 mb-2">Especialidad</p>
              <p class="text-gray-900 font-medium">{doctor.especialidad}</p>
            </div>
            {doctor.subespecialidad && (
              <div>
                <p class="text-xs tracking-[0.2em] uppercase text-gray-400 mb-2">Subespecialidad</p>
                <p class="text-gray-900 font-medium">{doctor.subespecialidad}</p>
              </div>
            )}
            {doctor.cedulaProfesional && (
              <div>
                <p class="text-xs tracking-[0.2em] uppercase text-gray-400 mb-2">Cédula</p>
                <p class="text-gray-900 font-medium">{doctor.cedulaProfesional}</p>
              </div>
            )}
          </div>
        </div>

        <!-- Números -->
        <div class="mt-12 flex gap-12">
          <div>
            <p class="text-4xl font-extralight text-gray-900">15+</p>
            <p class="text-xs tracking-[0.1em] uppercase text-gray-400 mt-1">Años</p>
          </div>
          <div>
            <p class="text-4xl font-extralight text-gray-900">5k+</p>
            <p class="text-xs tracking-[0.1em] uppercase text-gray-400 mt-1">Pacientes</p>
          </div>
          <div>
            <p class="text-4xl font-extralight text-gray-900">100%</p>
            <p class="text-xs tracking-[0.1em] uppercase text-gray-400 mt-1">Dedicación</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
