---
import type { DoctorConfig, Plantilla } from '../config/siteConfig';
import Icon from './Icon.astro';

interface Props {
  config: DoctorConfig;
  slug: string;
  plantilla: Plantilla;
}

const { config, slug, plantilla } = Astro.props;
const { doctor, logo, contacto, cta } = config;
const whatsappLink = `https://wa.me/${contacto.whatsapp}?text=${encodeURIComponent(cta.whatsappMensaje)}`;

const navItems = [
  { label: 'Inicio', href: '#inicio' },
  { label: 'Servicios', href: '#servicios' },
  { label: 'Sobre Mí', href: '#sobre-mi' },
  { label: 'Testimonios', href: '#testimonios' },
  { label: 'Contacto', href: '#contacto' },
];

// Plantillas con hero oscuro necesitan texto claro en el header
const darkHero = plantilla === 'moderna';
const textClass = darkHero ? 'text-white/80 hover:text-white' : 'text-gray-600 hover:text-gray-900';
const logoTextStyle = darkHero ? 'color: white' : `color: var(--color-primario)`;
const menuBtnClass = darkHero ? 'text-white hover:bg-white/10' : 'text-gray-600 hover:bg-gray-100';
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="main-header" data-dark-hero={darkHero ? 'true' : 'false'}>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="#inicio" class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold text-lg"
          style={`background-color: var(--color-primario)`}>
          {doctor.nombre.charAt(0)}
        </div>
        <span class="header-logo-text text-lg font-semibold tracking-tight hidden sm:block" style={logoTextStyle}>
          {doctor.titulo} {doctor.nombre.split(' ')[0]}
        </span>
      </a>

      <!-- Navigation Desktop -->
      <div class="hidden md:flex items-center gap-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`header-nav-link text-sm font-medium transition-colors relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:transition-all after:duration-300 hover:after:w-full ${textClass}`}
            style="--tw-after-bg: var(--color-secundario)"
          >
            {item.label}
          </a>
        ))}
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="px-6 py-2.5 text-white text-sm font-semibold rounded-full transition-all duration-300 hover:shadow-lg hover:scale-105"
          style={`background-color: var(--color-primario)`}
        >
          {cta.principal}
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class={`md:hidden p-2 rounded-lg header-menu-btn ${menuBtnClass}`}
        aria-label="Abrir menú"
      >
        <Icon name="menu" size={24} />
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t shadow-lg">
    <div class="px-4 py-6 space-y-4">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="block text-base font-medium text-gray-700 hover:text-gray-900 py-2"
        >
          {item.label}
        </a>
      ))}
      <a
        href={whatsappLink}
        target="_blank"
        rel="noopener noreferrer"
        class="block text-center px-6 py-3 text-white font-semibold rounded-full"
        style={`background-color: var(--color-primario)`}
      >
        {cta.principal}
      </a>
    </div>
  </div>
</header>

<script>
  // Header scroll effect
  const header = document.getElementById('main-header');
  const isDarkHero = header?.dataset.darkHero === 'true';

  function updateHeaderOnScroll() {
    if (!header) return;

    if (window.scrollY > 50) {
      header.classList.add('bg-white/95', 'backdrop-blur-md', 'shadow-sm');

      // Al hacer scroll, el fondo es blanco → texto oscuro siempre
      if (isDarkHero) {
        header.querySelectorAll('.header-nav-link').forEach((el) => {
          el.classList.remove('text-white/80', 'hover:text-white');
          el.classList.add('text-gray-600', 'hover:text-gray-900');
        });
        const logoText = header.querySelector('.header-logo-text') as HTMLElement;
        if (logoText) logoText.style.color = 'var(--color-primario)';
        const menuBtn = header.querySelector('.header-menu-btn');
        if (menuBtn) {
          menuBtn.classList.remove('text-white', 'hover:bg-white/10');
          menuBtn.classList.add('text-gray-600', 'hover:bg-gray-100');
        }
      }
    } else {
      header.classList.remove('bg-white/95', 'backdrop-blur-md', 'shadow-sm');

      // Sin scroll → restaurar colores originales según plantilla
      if (isDarkHero) {
        header.querySelectorAll('.header-nav-link').forEach((el) => {
          el.classList.add('text-white/80', 'hover:text-white');
          el.classList.remove('text-gray-600', 'hover:text-gray-900');
        });
        const logoText = header.querySelector('.header-logo-text') as HTMLElement;
        if (logoText) logoText.style.color = 'white';
        const menuBtn = header.querySelector('.header-menu-btn');
        if (menuBtn) {
          menuBtn.classList.add('text-white', 'hover:bg-white/10');
          menuBtn.classList.remove('text-gray-600', 'hover:bg-gray-100');
        }
      }
    }
  }

  window.addEventListener('scroll', updateHeaderOnScroll);

  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });
</script>
