---
/**
 * PLANTILLA PREMIUM - Sobre Mí Section
 * Diseño editorial oscuro con acentos dorados.
 */
import type { DoctorConfig } from '../../config/siteConfig';
import Icon from '../Icon.astro';

interface Props { config: DoctorConfig; }
const { config } = Astro.props;
const { doctor } = config;
---

<section id="sobre-mi" class="py-32 bg-[#0D0D0D] relative overflow-hidden">
  <!-- Elementos decorativos -->
  <div class="absolute top-0 right-0 w-1/2 h-full bg-[#C9A96E]/5"></div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Imagen con marco premium -->
      <div class="relative">
        <!-- Marco exterior -->
        <div class="absolute -inset-6 border border-[#C9A96E]/20"></div>
        
        <div class="relative aspect-[4/5] overflow-hidden">
          <img 
            src={doctor.foto} 
            alt={`${doctor.titulo} ${doctor.nombre}`}
            class="w-full h-full object-cover"
            loading="lazy"
          />
          <!-- Overlay gradiente -->
          <div class="absolute inset-0 bg-gradient-to-t from-[#0D0D0D]/60 to-transparent"></div>
        </div>

        <!-- Badge de experiencia -->
        <div class="absolute -bottom-4 -left-4 bg-[#C9A96E] p-6 text-[#0D0D0D]">
          <p class="text-3xl font-light">15+</p>
          <p class="text-xs tracking-wider uppercase">Años de experiencia</p>
        </div>
      </div>

      <!-- Contenido -->
      <div class="lg:pl-8">
        <!-- Label -->
        <div class="flex items-center gap-4 mb-8">
          <div class="w-12 h-px bg-[#C9A96E]"></div>
          <span class="text-[#C9A96E] text-xs tracking-[0.2em] uppercase">Sobre Mí</span>
        </div>

        <!-- Título -->
        <h2 class="text-4xl md:text-5xl font-light text-white mb-6 leading-tight">
          <span class="text-[#C9A96E]">{doctor.titulo}</span><br />
          {doctor.nombre}
        </h2>

        <!-- Especialidad -->
        <div class="flex items-center gap-3 mb-8">
          <Icon name="award" size={20} class="text-[#C9A96E]" />
          <span class="text-white/80">{doctor.especialidad}</span>
          {doctor.subespecialidad && (
            <>
              <span class="text-white/30">•</span>
              <span class="text-white/60">{doctor.subespecialidad}</span>
            </>
          )}
        </div>

        <!-- Biografía -->
        <div class="border-l-2 border-[#C9A96E]/30 pl-6 mb-10">
          <p class="text-white/70 font-light leading-relaxed text-lg">
            {doctor.biografia}
          </p>
        </div>

        <!-- Credenciales -->
        <div class="grid grid-cols-2 gap-6 mb-10">
          {doctor.cedulaProfesional && (
            <div class="p-4 border border-white/10 bg-white/5">
              <p class="text-[#C9A96E] text-xs tracking-wider uppercase mb-1">Cédula Profesional</p>
              <p class="text-white font-medium">{doctor.cedulaProfesional}</p>
            </div>
          )}
          <div class="p-4 border border-white/10 bg-white/5">
            <p class="text-[#C9A96E] text-xs tracking-wider uppercase mb-1">Especialidad</p>
            <p class="text-white font-medium">{doctor.especialidad}</p>
          </div>
        </div>

        <!-- Stats en línea -->
        <div class="flex gap-8 pt-8 border-t border-white/10">
          <div>
            <p class="text-3xl font-light text-[#C9A96E]">5,000+</p>
            <p class="text-white/50 text-xs tracking-wider uppercase mt-1">Pacientes</p>
          </div>
          <div>
            <p class="text-3xl font-light text-[#C9A96E]">100%</p>
            <p class="text-white/50 text-xs tracking-wider uppercase mt-1">Compromiso</p>
          </div>
          <div>
            <p class="text-3xl font-light text-[#C9A96E]">★ 5.0</p>
            <p class="text-white/50 text-xs tracking-wider uppercase mt-1">Valoraciones</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
