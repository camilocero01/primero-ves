---
/**
 * PLANTILLA PREMIUM - Instalaciones Section
 * Slider elegante con estilo cinematográfico.
 */
import type { DoctorConfig } from '../../config/siteConfig';
import Icon from '../Icon.astro';

interface Props { config: DoctorConfig; }
const { config } = Astro.props;
const { imagenes } = config;
---

<section id="instalaciones" class="py-32 bg-[#0A0A0A] relative">
  <!-- Línea dorada superior -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#C9A96E]/30 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-6">
    <!-- Encabezado -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-16">
      <div>
        <div class="flex items-center gap-4 mb-4">
          <div class="w-12 h-px bg-[#C9A96E]"></div>
          <span class="text-[#C9A96E] text-xs tracking-[0.2em] uppercase">Instalaciones</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-light text-white">
          Espacios <span class="text-[#C9A96E]">Premium</span>
        </h2>
      </div>
      <p class="text-white/60 font-light max-w-md">
        Ambientes diseñados para brindarle comodidad y tranquilidad durante su visita
      </p>
    </div>

    <!-- Grid de instalaciones -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      {imagenes.instalaciones.map((img, index) => (
        <figure 
          class={`relative group overflow-hidden ${index === 0 ? 'lg:col-span-2 lg:row-span-2' : ''}`}
        >
          <div class={`${index === 0 ? 'aspect-square' : 'aspect-[4/3]'} overflow-hidden`}>
            <img 
              src={img.url} 
              alt={img.alt}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
            />
          </div>
          
          <!-- Overlay oscuro -->
          <div class="absolute inset-0 bg-[#0D0D0D]/60 group-hover:bg-[#0D0D0D]/40 transition-all duration-500"></div>
          
          <!-- Contenido -->
          <div class="absolute inset-0 p-6 flex flex-col justify-between">
            <!-- Número -->
            <span class="text-[#C9A96E] text-xs tracking-[0.2em]">0{index + 1}</span>
            
            <!-- Título -->
            <div>
              <h3 class="text-white font-medium mb-2">{img.alt}</h3>
              <div class="w-8 h-px bg-[#C9A96E] group-hover:w-16 transition-all duration-500"></div>
            </div>
          </div>

          <!-- Borde dorado -->
          <div class="absolute inset-0 border border-[#C9A96E]/0 group-hover:border-[#C9A96E]/30 transition-all duration-500"></div>
        </figure>
      ))}
    </div>

    <!-- Footer de sección -->
    <div class="mt-16 flex items-center justify-center gap-8">
      <div class="w-20 h-px bg-gradient-to-r from-transparent to-[#C9A96E]/30"></div>
      <span class="text-[#C9A96E]/50 text-xs tracking-[0.3em] uppercase">Confort & Excelencia</span>
      <div class="w-20 h-px bg-gradient-to-l from-transparent to-[#C9A96E]/30"></div>
    </div>
  </div>
</section>
