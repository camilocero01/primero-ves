---
import type { DoctorConfig, Plantilla } from '../config/siteConfig';
import Icon from './Icon.astro';

interface Props {
  config: DoctorConfig;
  slug: string;
  plantilla: Plantilla;
}

const { config, slug, plantilla } = Astro.props;
const { doctor, contacto, redesSociales, seo } = config;

const socialLinks = Object.entries(redesSociales).filter(([_, url]) => url);

const baseUrl = `/${slug}`;
---

<footer class="text-white" style={`background-color: var(--color-primario)`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Info del doctor -->
      <div>
        <h3 class="text-2xl font-bold mb-4 font-heading">
          {doctor.titulo} {doctor.nombre}
        </h3>
        <p class="text-white/70 mb-6">{doctor.especialidad}</p>
        {doctor.cedulaProfesional && (
          <p class="text-white/50 text-sm">
            Cédula Profesional: {doctor.cedulaProfesional}
          </p>
        )}
      </div>

      <!-- Contacto rápido -->
      <div>
        <h4 class="text-lg font-semibold mb-4" style={`color: var(--color-secundario)`}>
          Contacto
        </h4>
        <div class="space-y-3">
          <a href={`tel:${contacto.telefono}`} class="flex items-center gap-3 text-white/70 hover:text-white transition-colors">
            <Icon name="phone" size={18} />
            <span>{contacto.telefono}</span>
          </a>
          <a href={`mailto:${contacto.email}`} class="flex items-center gap-3 text-white/70 hover:text-white transition-colors">
            <Icon name="mail" size={18} />
            <span>{contacto.email}</span>
          </a>
          <div class="flex items-start gap-3 text-white/70">
            <Icon name="map-pin" size={18} class="mt-0.5 shrink-0" />
            <span>{contacto.direccion}, {contacto.ciudad}, {contacto.estado}</span>
          </div>
        </div>
      </div>

      <!-- Redes Sociales -->
      <div>
        <h4 class="text-lg font-semibold mb-4" style={`color: var(--color-secundario)`}>
          Síguenos
        </h4>
        <div class="flex gap-4">
          {socialLinks.map(([name, url]) => (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors"
              aria-label={name}
            >
              <Icon name={name} size={18} />
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Separador -->
    <div class="border-t border-white/10 mt-12 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-white/40 text-sm">
        &copy; {new Date().getFullYear()} {doctor.titulo} {doctor.nombre}. Todos los derechos reservados.
      </p>
      <p class="text-white/30 text-xs">
        Diseñado por <a href="https://primeroves.com" class="hover:text-white/60 transition-colors" style={`color: var(--color-secundario)`}>PrimeroVes</a>
      </p>
    </div>
  </div>
</footer>

<!-- Switcher flotante de plantillas -->
<div id="template-switcher" class="fixed bottom-6 left-6 z-50">
  <div class="relative">
    <!-- Botón toggle -->
    <button
      id="switcher-btn"
      class="flex items-center gap-2 px-4 py-3 bg-slate-900 text-white text-sm font-medium rounded-full shadow-lg border border-white/10 hover:bg-slate-800 transition-all duration-300 hover:shadow-xl"
      aria-label="Cambiar plantilla"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
      <span>Plantilla</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200" id="switcher-chevron"><polyline points="6 9 12 15 18 9"/></svg>
    </button>

    <!-- Dropdown -->
    <div id="switcher-dropdown" class="hidden absolute bottom-full left-0 mb-2 w-56 bg-slate-900 border border-white/10 rounded-2xl shadow-2xl overflow-hidden">
      <div class="p-2">
        <p class="text-white/40 text-xs font-medium uppercase tracking-wider px-3 py-2">Cambiar plantilla</p>
        
        <a href={`${baseUrl}/elegante`} class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-white/80 hover:bg-white/10 hover:text-white transition-colors group" data-template="elegante">
          <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-[#1B4D6E] to-[#1B4D6E]/70 flex items-center justify-center text-xs font-bold text-white shrink-0">E</span>
          <div>
            <p class="text-sm font-medium">Elegante</p>
            <p class="text-xs text-white/40">Sofisticada y prestigiosa</p>
          </div>
        </a>

        <a href={`${baseUrl}/moderna`} class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-white/80 hover:bg-white/10 hover:text-white transition-colors group" data-template="moderna">
          <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-[#1B4D6E] to-[#0D2B3E] flex items-center justify-center text-xs font-bold text-white shrink-0">M</span>
          <div>
            <p class="text-sm font-medium">Moderna</p>
            <p class="text-xs text-white/40">Audaz e impactante</p>
          </div>
        </a>

        <a href={`${baseUrl}/clasica`} class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-white/80 hover:bg-white/10 hover:text-white transition-colors group" data-template="clasica">
          <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-gray-300 to-gray-400 flex items-center justify-center text-xs font-bold text-gray-700 shrink-0">C</span>
          <div>
            <p class="text-sm font-medium">Clásica</p>
            <p class="text-xs text-white/40">Sólida y tradicional</p>
          </div>
        </a>

        <div class="border-t border-white/5 mt-1 pt-1">
          <a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-white/50 hover:bg-white/10 hover:text-white transition-colors text-sm">
            <span class="w-8 h-8 rounded-lg bg-amber-400/20 flex items-center justify-center text-amber-400 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </span>
            Volver al inicio
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Template switcher toggle
  const btn = document.getElementById('switcher-btn');
  const dropdown = document.getElementById('switcher-dropdown');
  const chevron = document.getElementById('switcher-chevron');

  btn?.addEventListener('click', () => {
    dropdown?.classList.toggle('hidden');
    chevron?.classList.toggle('rotate-180');
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!document.getElementById('template-switcher')?.contains(e.target as Node)) {
      dropdown?.classList.add('hidden');
      chevron?.classList.remove('rotate-180');
    }
  });

  // Highlight current template
  const currentPath = window.location.pathname.replace(/\/$/, '').split('/').pop();
  const activeLink = document.querySelector(`[data-template="${currentPath}"]`);
  if (activeLink) {
    activeLink.classList.add('bg-white/10');
    const dot = document.createElement('span');
    dot.className = 'w-1.5 h-1.5 rounded-full bg-green-400 ml-auto shrink-0';
    activeLink.appendChild(dot);
  }
</script>
