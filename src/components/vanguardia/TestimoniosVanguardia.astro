---
/**
 * PLANTILLA VANGUARDIA - Testimonios Section
 * Cards con glassmorphism y efectos de hover modernos.
 */
import type { DoctorConfig } from '../../config/siteConfig';
import Icon from '../Icon.astro';

interface Props { config: DoctorConfig; }
const { config } = Astro.props;
const { testimonios, doctor } = config;
---

<section id="testimonios" class="py-32 bg-slate-950 relative overflow-hidden">
  <!-- Background effects -->
  <div class="absolute inset-0">
    <div class="absolute top-1/4 left-0 w-[500px] h-[500px] bg-violet-500/10 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-1/4 right-0 w-[500px] h-[500px] bg-cyan-500/10 rounded-full blur-[120px]"></div>
  </div>

  <!-- Decorative circles -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full border border-white/5"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full border border-white/5"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <!-- Encabezado -->
    <div class="text-center max-w-3xl mx-auto mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 backdrop-blur-sm border border-white/10 mb-6">
        <Icon name="message-circle" size={16} class="text-fuchsia-400" />
        <span class="text-white/70 text-xs tracking-widest uppercase">Testimonios</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
        Historias de <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 via-fuchsia-400 to-cyan-400">éxito</span>
      </h2>
      <p class="text-white/60 font-light">
        La satisfacción de nuestros pacientes habla por sí misma
      </p>
    </div>

    <!-- Grid de testimonios -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonios.map((testimonio, index) => (
        <article 
          class={`group relative ${index === 1 ? 'md:-translate-y-8' : ''}`}
        >
          <!-- Card con glassmorphism -->
          <div class="relative p-6 rounded-3xl bg-white/5 backdrop-blur-sm border border-white/10 hover:border-violet-500/30 transition-all duration-500 overflow-hidden">
            <!-- Gradient glow -->
            <div class="absolute -inset-px rounded-3xl bg-gradient-to-r from-violet-500/0 via-fuchsia-500/0 to-cyan-500/0 group-hover:from-violet-500/10 group-hover:via-fuchsia-500/10 group-hover:to-cyan-500/10 transition-all duration-500 -z-10 blur-xl"></div>

            <!-- Quote icon -->
            <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-violet-500/20 to-cyan-500/20 flex items-center justify-center mb-6">
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-cyan-400 text-2xl font-serif">"</span>
            </div>

            <!-- Testimonio -->
            <blockquote class="text-white/80 font-light leading-relaxed mb-6">
              {testimonio.texto}
            </blockquote>

            <!-- Rating con estrellas -->
            <div class="flex gap-1 mb-6">
              {Array.from({ length: 5 }).map((_, i) => (
                <Icon 
                  name="star" 
                  size={16} 
                  class={i < testimonio.calificacion ? 'text-transparent fill-current' : 'text-white/20'}
                  style={i < testimonio.calificacion ? 'color: transparent; background: linear-gradient(to right, #8b5cf6, #06b6d4); -webkit-background-clip: text; background-clip: text;' : ''}
                />
              ))}
            </div>

            <!-- Autor -->
            <footer class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-violet-500 to-cyan-500 p-px">
                <div class="w-full h-full rounded-full bg-slate-950 flex items-center justify-center">
                  <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-cyan-400 font-bold">
                    {testimonio.nombre.charAt(0)}
                  </span>
                </div>
              </div>
              <div>
                <cite class="not-italic text-white font-medium block">
                  {testimonio.nombre}
                </cite>
                <div class="flex items-center gap-2">
                  <Icon name="check-circle" size={12} class="text-cyan-400" />
                  <span class="text-white/50 text-xs">Verificado</span>
                </div>
              </div>
            </footer>
          </div>
        </article>
      ))}
    </div>

    <!-- Stats de confianza -->
    <div class="mt-20 p-8 rounded-3xl bg-gradient-to-r from-violet-500/10 via-fuchsia-500/10 to-cyan-500/10 border border-white/10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="text-center">
          <p class="text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-fuchsia-400">5,000+</p>
          <p class="text-white/50 text-sm mt-2">Pacientes felices</p>
        </div>
        <div class="text-center">
          <p class="text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-fuchsia-400 to-cyan-400">★ 5.0</p>
          <p class="text-white/50 text-sm mt-2">Calificación</p>
        </div>
        <div class="text-center">
          <p class="text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-violet-400">98%</p>
          <p class="text-white/50 text-sm mt-2">Recomiendan</p>
        </div>
        <div class="text-center">
          <p class="text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-cyan-400">500+</p>
          <p class="text-white/50 text-sm mt-2">Reseñas online</p>
        </div>
      </div>
    </div>
  </div>
</section>
