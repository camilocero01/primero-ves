---
/**
 * PLANTILLA VANGUARDIA - Sobre Mí Section
 * Diseño asimétrico con efectos futuristas.
 */
import type { DoctorConfig } from '../../config/siteConfig';
import Icon from '../Icon.astro';

interface Props { config: DoctorConfig; }
const { config } = Astro.props;
const { doctor } = config;
---

<section id="sobre-mi" class="py-32 bg-slate-950 relative overflow-hidden">
  <!-- Background effects -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-violet-500/10 rounded-full blur-[120px]"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-cyan-500/10 rounded-full blur-[100px]"></div>

  <!-- Grid pattern -->
  <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size: 60px 60px;"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <!-- Imagen con efectos -->
      <div class="lg:col-span-5 relative">
        <!-- Glow -->
        <div class="absolute -inset-4 bg-gradient-to-br from-violet-500/20 via-fuchsia-500/20 to-cyan-500/20 rounded-3xl blur-2xl"></div>
        
        <!-- Imagen con borde gradiente -->
        <div class="relative rounded-3xl p-1 bg-gradient-to-br from-violet-500 via-fuchsia-500 to-cyan-500">
          <div class="rounded-[22px] overflow-hidden bg-slate-950">
            <img 
              src={doctor.foto} 
              alt={`${doctor.titulo} ${doctor.nombre}`}
              class="w-full aspect-[4/5] object-cover"
              loading="lazy"
            />
          </div>
        </div>

        <!-- Floating stats -->
        <div class="absolute -right-4 top-1/4 p-4 rounded-2xl bg-white/10 backdrop-blur-md border border-white/20">
          <p class="text-3xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-cyan-400">15+</p>
          <p class="text-white/60 text-xs">Años</p>
        </div>

        <div class="absolute -left-4 bottom-1/4 p-4 rounded-2xl bg-white/10 backdrop-blur-md border border-white/20">
          <p class="text-3xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-fuchsia-400 to-cyan-400">5k+</p>
          <p class="text-white/60 text-xs">Pacientes</p>
        </div>
      </div>

      <!-- Contenido -->
      <div class="lg:col-span-7 lg:pl-8">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 backdrop-blur-sm border border-white/10 mb-6">
          <Icon name="user" size={16} class="text-cyan-400" />
          <span class="text-white/70 text-xs tracking-widest uppercase">Sobre Mí</span>
        </div>

        <!-- Título -->
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-2">
          {doctor.titulo}
        </h2>
        <h3 class="text-3xl md:text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-violet-400 via-fuchsia-400 to-cyan-400 mb-6">
          {doctor.nombre}
        </h3>

        <!-- Especialidad badges -->
        <div class="flex flex-wrap gap-3 mb-8">
          <span class="px-4 py-2 rounded-full bg-violet-500/20 border border-violet-500/30 text-violet-300 text-sm">
            {doctor.especialidad}
          </span>
          {doctor.subespecialidad && (
            <span class="px-4 py-2 rounded-full bg-cyan-500/20 border border-cyan-500/30 text-cyan-300 text-sm">
              {doctor.subespecialidad}
            </span>
          )}
        </div>

        <!-- Biografía -->
        <div class="relative pl-6 mb-10">
          <div class="absolute left-0 top-0 bottom-0 w-1 bg-gradient-to-b from-violet-500 via-fuchsia-500 to-cyan-500 rounded-full"></div>
          <p class="text-white/70 font-light leading-relaxed text-lg">
            {doctor.biografia}
          </p>
        </div>

        <!-- Credenciales en cards -->
        <div class="grid grid-cols-2 gap-4 mb-10">
          {doctor.cedulaProfesional && (
            <div class="p-4 rounded-2xl bg-white/5 backdrop-blur-sm border border-white/10">
              <div class="flex items-center gap-2 mb-2">
                <Icon name="file-badge" size={16} class="text-violet-400" />
                <span class="text-white/50 text-xs tracking-wider uppercase">Cédula</span>
              </div>
              <p class="text-white font-medium">{doctor.cedulaProfesional}</p>
            </div>
          )}
          <div class="p-4 rounded-2xl bg-white/5 backdrop-blur-sm border border-white/10">
            <div class="flex items-center gap-2 mb-2">
              <Icon name="award" size={16} class="text-cyan-400" />
              <span class="text-white/50 text-xs tracking-wider uppercase">Certificado</span>
            </div>
            <p class="text-white font-medium">Consejo de Especialidad</p>
          </div>
        </div>

        <!-- Stats row -->
        <div class="flex gap-8 p-6 rounded-2xl bg-gradient-to-r from-violet-500/10 via-fuchsia-500/10 to-cyan-500/10 border border-white/10">
          <div class="text-center">
            <p class="text-2xl font-bold text-white">100%</p>
            <p class="text-white/50 text-xs">Compromiso</p>
          </div>
          <div class="w-px bg-white/10"></div>
          <div class="text-center">
            <p class="text-2xl font-bold text-white">★ 5.0</p>
            <p class="text-white/50 text-xs">Valoración</p>
          </div>
          <div class="w-px bg-white/10"></div>
          <div class="text-center">
            <p class="text-2xl font-bold text-white">24/7</p>
            <p class="text-white/50 text-xs">Disponible</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
