---
/**
 * PLANTILLA VANGUARDIA - Contacto Section
 * Diseño futurista con mapa y cards de contacto.
 */
import type { DoctorConfig } from '../../config/siteConfig';
import Icon from '../Icon.astro';

interface Props { config: DoctorConfig; }
const { config } = Astro.props;
const { contacto, horarios, cta, doctor, redesSociales } = config;
const whatsappLink = `https://wa.me/${contacto.whatsapp}?text=${encodeURIComponent(cta.whatsappMensaje)}`;
---

<section id="contacto" class="py-32 bg-slate-950 relative overflow-hidden">
  <!-- Background effects -->
  <div class="absolute inset-0">
    <div class="absolute top-0 left-0 w-[600px] h-[600px] bg-violet-500/10 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-cyan-500/10 rounded-full blur-[100px]"></div>
  </div>

  <!-- Grid pattern -->
  <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size: 60px 60px;"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <!-- Encabezado -->
    <div class="text-center max-w-3xl mx-auto mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 backdrop-blur-sm border border-white/10 mb-6">
        <Icon name="map-pin" size={16} class="text-cyan-400" />
        <span class="text-white/70 text-xs tracking-widest uppercase">Contacto</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
        Conecta con <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-cyan-400">nosotros</span>
      </h2>
      <p class="text-white/60 font-light">
        Estamos listos para atenderte con la mejor tecnología
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Cards de contacto -->
      <div class="space-y-6">
        <!-- Ubicación card -->
        <div class="p-6 rounded-3xl bg-white/5 backdrop-blur-sm border border-white/10 hover:border-violet-500/30 transition-all duration-500 group">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-violet-500/20 to-cyan-500/20 flex items-center justify-center flex-shrink-0 group-hover:from-violet-500/30 group-hover:to-cyan-500/30 transition-all duration-300">
              <Icon name="map-pin" size={24} class="text-cyan-400" />
            </div>
            <div>
              <p class="text-white/50 text-xs tracking-wider uppercase mb-2">Ubicación</p>
              <a 
                href={contacto.googleMapsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-white font-light hover:text-cyan-400 transition-colors duration-300"
              >
                {contacto.direccion}<br />
                {contacto.ciudad}, {contacto.estado}
              </a>
            </div>
          </div>
        </div>

        <!-- Grid de contactos -->
        <div class="grid grid-cols-2 gap-4">
          <!-- Teléfono -->
          <div class="p-5 rounded-2xl bg-white/5 backdrop-blur-sm border border-white/10 hover:border-violet-500/30 transition-all duration-500">
            <div class="flex items-center gap-3 mb-3">
              <Icon name="phone" size={18} class="text-violet-400" />
              <span class="text-white/50 text-xs tracking-wider uppercase">Teléfono</span>
            </div>
            <a 
              href={`tel:${contacto.telefono}`}
              class="text-white font-light text-sm hover:text-violet-400 transition-colors duration-300"
            >
              {contacto.telefono}
            </a>
          </div>

          <!-- WhatsApp -->
          <div class="p-5 rounded-2xl bg-white/5 backdrop-blur-sm border border-white/10 hover:border-cyan-500/30 transition-all duration-500">
            <div class="flex items-center gap-3 mb-3">
              <Icon name="whatsapp" size={18} class="text-cyan-400" />
              <span class="text-white/50 text-xs tracking-wider uppercase">WhatsApp</span>
            </div>
            <a 
              href={whatsappLink}
              target="_blank"
              rel="noopener noreferrer"
              class="text-white font-light text-sm hover:text-cyan-400 transition-colors duration-300"
            >
              Enviar mensaje
            </a>
          </div>
        </div>

        <!-- Email -->
        <div class="p-5 rounded-2xl bg-white/5 backdrop-blur-sm border border-white/10 hover:border-fuchsia-500/30 transition-all duration-500">
          <div class="flex items-center gap-3 mb-3">
            <Icon name="mail" size={18} class="text-fuchsia-400" />
            <span class="text-white/50 text-xs tracking-wider uppercase">Email</span>
          </div>
          <a 
            href={`mailto:${contacto.email}`}
            class="text-white font-light hover:text-fuchsia-400 transition-colors duration-300"
          >
            {contacto.email}
          </a>
        </div>

        <!-- Horarios con estilo especial -->
        <div class="p-6 rounded-3xl bg-gradient-to-r from-violet-500/10 via-fuchsia-500/10 to-cyan-500/10 border border-white/10">
          <div class="flex items-center gap-3 mb-6">
            <Icon name="clock" size={20} class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-cyan-400" />
            <span class="text-white font-medium">Horarios de Atención</span>
          </div>
          <div class="space-y-3">
            {horarios.map((horario) => (
              <div class="flex justify-between items-center py-2 border-b border-white/10 last:border-0">
                <span class="text-white/60 text-sm">{horario.dias}</span>
                <span class="text-white font-medium text-sm">{horario.horas}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Redes sociales -->
        <div class="flex items-center gap-4">
          <span class="text-white/50 text-xs tracking-wider uppercase">Síguenos:</span>
          <div class="flex gap-3">
            {redesSociales.facebook && (
              <a href={redesSociales.facebook} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-white/60 hover:border-violet-500/50 hover:text-violet-400 transition-all duration-300" aria-label="Facebook">
                <Icon name="facebook" size={18} />
              </a>
            )}
            {redesSociales.instagram && (
              <a href={redesSociales.instagram} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-white/60 hover:border-fuchsia-500/50 hover:text-fuchsia-400 transition-all duration-300" aria-label="Instagram">
                <Icon name="instagram" size={18} />
              </a>
            )}
            {redesSociales.linkedin && (
              <a href={redesSociales.linkedin} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-white/60 hover:border-cyan-500/50 hover:text-cyan-400 transition-all duration-300" aria-label="LinkedIn">
                <Icon name="linkedin" size={18} />
              </a>
            )}
          </div>
        </div>

        <!-- CTA principal -->
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="w-full inline-flex items-center justify-center gap-3 px-8 py-5 rounded-2xl bg-gradient-to-r from-violet-600 to-cyan-600 text-white font-semibold hover:shadow-lg hover:shadow-violet-500/25 transition-all duration-500 group"
        >
          <Icon name="whatsapp" size={20} />
          <span>{cta.principal} por WhatsApp</span>
          <Icon name="arrow-right" size={18} class="transition-transform duration-300 group-hover:translate-x-1" />
        </a>
      </div>

      <!-- Mapa con estilo futurista -->
      <div class="relative">
        <div class="sticky top-8">
          <!-- Glow effect -->
          <div class="absolute -inset-4 bg-gradient-to-r from-violet-500/20 via-fuchsia-500/20 to-cyan-500/20 rounded-3xl blur-2xl"></div>
          
          <!-- Mapa con borde gradiente -->
          <div class="relative rounded-3xl p-1 bg-gradient-to-br from-violet-500 via-fuchsia-500 to-cyan-500">
            <div class="rounded-[22px] overflow-hidden bg-slate-950">
              <div class="aspect-square lg:aspect-auto lg:h-[500px]">
                <iframe
                  src={contacto.googleMapsEmbed}
                  width="100%"
                  height="100%"
                  style="border:0; filter: saturate(0.8) brightness(0.8) contrast(1.1);"
                  allowfullscreen=""
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title={`Ubicación de ${doctor.titulo} ${doctor.nombre}`}
                ></iframe>
              </div>
            </div>
          </div>

          <!-- Card flotante -->
          <div class="absolute bottom-6 left-6 right-6 p-4 rounded-2xl bg-slate-950/90 backdrop-blur-md border border-white/20">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-violet-500 to-cyan-500 flex items-center justify-center flex-shrink-0">
                <Icon name="navigation" size={20} class="text-white" />
              </div>
              <div>
                <p class="text-white font-medium">{doctor.titulo} {doctor.nombre}</p>
                <p class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-cyan-400 text-sm">{doctor.especialidad}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
