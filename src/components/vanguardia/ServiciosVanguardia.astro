---
/**
 * PLANTILLA VANGUARDIA - Servicios Section
 * Cards con glassmorphism y bordes con gradiente.
 */
import type { DoctorConfig } from '../../config/siteConfig';
import Icon from '../Icon.astro';

interface Props { config: DoctorConfig; }
const { config } = Astro.props;
const { servicios } = config;
---

<section id="servicios" class="py-32 bg-slate-950 relative overflow-hidden">
  <!-- Background effects -->
  <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-violet-500/10 rounded-full blur-[100px]"></div>
  <div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-cyan-500/10 rounded-full blur-[80px]"></div>

  <!-- Grid pattern -->
  <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 60px 60px;"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <!-- Encabezado -->
    <div class="text-center max-w-3xl mx-auto mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 backdrop-blur-sm border border-white/10 mb-6">
        <Icon name="layers" size={16} class="text-violet-400" />
        <span class="text-white/70 text-xs tracking-widest uppercase">Servicios</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
        Tecnología al servicio de tu <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-cyan-400">salud</span>
      </h2>
      <p class="text-white/60 font-light">
        Procedimientos de vanguardia con los más altos estándares de calidad
      </p>
    </div>

    <!-- Grid de servicios con Bento layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {servicios.map((servicio, index) => (
        <article 
          class={`group relative p-6 rounded-3xl bg-white/5 backdrop-blur-sm border border-white/10 hover:border-violet-500/50 transition-all duration-500 overflow-hidden ${index === 0 ? 'lg:col-span-2 lg:row-span-1' : ''}`}
        >
          <!-- Gradient glow on hover -->
          <div class="absolute -inset-px rounded-3xl bg-gradient-to-r from-violet-500/0 via-fuchsia-500/0 to-cyan-500/0 group-hover:from-violet-500/20 group-hover:via-fuchsia-500/20 group-hover:to-cyan-500/20 transition-all duration-500 -z-10 blur-xl"></div>

          <div class="flex items-start gap-4">
            <!-- Icono con gradiente -->
            <div class="flex-shrink-0 w-12 h-12 rounded-2xl bg-gradient-to-br from-violet-500/20 to-cyan-500/20 flex items-center justify-center group-hover:from-violet-500/30 group-hover:to-cyan-500/30 transition-all duration-300">
              <Icon name={servicio.icono} size={24} class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-cyan-400" />
            </div>

            <div class="flex-1">
              <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-violet-400 group-hover:to-cyan-400 transition-all duration-300">
                {servicio.nombre}
              </h3>
              <p class="text-white/60 text-sm leading-relaxed">
                {servicio.descripcion}
              </p>
            </div>
          </div>

          <!-- Animated corner -->
          <div class="absolute bottom-0 right-0 w-20 h-20">
            <div class="absolute bottom-4 right-4 w-8 h-8 border-b-2 border-r-2 border-white/10 group-hover:border-violet-500/50 rounded-br-lg transition-all duration-500"></div>
          </div>
        </article>
      ))}
    </div>

    <!-- Decorative element -->
    <div class="mt-16 flex items-center justify-center">
      <div class="flex items-center gap-4">
        <div class="w-12 h-px bg-gradient-to-r from-transparent to-violet-500"></div>
        <div class="w-2 h-2 rounded-full bg-gradient-to-r from-violet-500 to-cyan-500"></div>
        <div class="w-12 h-px bg-gradient-to-l from-transparent to-cyan-500"></div>
      </div>
    </div>
  </div>
</section>
