---
/**
 * PLANTILLA CLÁSICA - Hero Section
 * Diseño tradicional y sobrio, split 50/50, transmite solidez y trayectoria.
 */
import type { DoctorConfig } from '../../config/siteConfig';
import Icon from '../Icon.astro';

interface Props { config: DoctorConfig; }
const { config } = Astro.props;
const { doctor, contacto, cta, imagenes } = config;
const whatsappLink = `https://wa.me/${contacto.whatsapp}?text=${encodeURIComponent(cta.whatsappMensaje)}`;
---

<section id="inicio" class="relative min-h-screen flex items-center">
  <div class="w-full grid grid-cols-1 lg:grid-cols-2 min-h-screen">
    <!-- Lado izquierdo - Contenido con imagen de fondo sutil -->
    <div class="relative flex items-center justify-center px-8 sm:px-12 lg:px-16 py-32">
      <div class="absolute inset-0">
        <img src={imagenes.heroFondo} alt="" class="w-full h-full object-cover" loading="eager" />
        <div class="absolute inset-0 bg-white/95"></div>
      </div>
      <div class="relative max-w-lg animate-fade-in">
        <!-- Línea decorativa -->
        <div class="w-16 h-1 mb-8" style={`background-color: var(--color-secundario)`}></div>
        
        <p class="text-sm font-semibold tracking-[0.3em] uppercase mb-4" style={`color: var(--color-secundario)`}>
          {doctor.especialidad}
        </p>
        
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6" style={`color: var(--color-primario)`}>
          {doctor.titulo}<br />{doctor.nombre}
        </h1>
        
        <p class="text-xl text-gray-500 italic font-heading mb-4">
          "{doctor.frase}"
        </p>
        
        {doctor.subespecialidad && (
          <p class="text-gray-600 mb-8">
            {doctor.subespecialidad}
          </p>
        )}
        
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a
            href={whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 text-white font-semibold transition-all duration-300 hover:shadow-lg"
            style={`background-color: var(--color-primario)`}
          >
            {cta.principal}
            <Icon name="arrow-right" size={18} />
          </a>
          <a
            href="#servicios"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 border-2 font-semibold transition-all duration-300"
            style={`border-color: var(--color-primario); color: var(--color-primario)`}
          >
            {cta.secundario}
          </a>
        </div>

        <!-- Info rápida -->
        <div class="grid grid-cols-3 gap-6 pt-8 border-t border-gray-200">
          <div class="text-center">
            <Icon name="phone" size={20} class="mx-auto mb-2" style={`color: var(--color-secundario)`} />
            <p class="text-xs text-gray-500">Teléfono</p>
          </div>
          <div class="text-center">
            <Icon name="calendar" size={20} class="mx-auto mb-2" style={`color: var(--color-secundario)`} />
            <p class="text-xs text-gray-500">Agenda</p>
          </div>
          <div class="text-center">
            <Icon name="map-pin" size={20} class="mx-auto mb-2" style={`color: var(--color-secundario)`} />
            <p class="text-xs text-gray-500">{contacto.ciudad}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Lado derecho - Imagen -->
    <div class="relative hidden lg:block">
      <img
        src={doctor.foto}
        alt={`${doctor.titulo} ${doctor.nombre} - ${doctor.especialidad}`}
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0" style={`background: linear-gradient(135deg, transparent 50%, color-mix(in srgb, var(--color-primario) 30%, transparent))`}></div>
    </div>
  </div>
</section>
