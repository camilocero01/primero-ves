---
import { siteConfig } from '../../config/siteConfig';
import Icon from '../Icon.astro';

const { servicios } = siteConfig;
---

<section id="servicios" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center mb-16">
      <div class="w-16 h-1 mx-auto mb-6" style={`background-color: var(--color-secundario)`}></div>
      <h2 class="text-4xl md:text-5xl font-bold mb-6" style={`color: var(--color-primario)`}>
        Servicios Médicos
      </h2>
      <p class="text-gray-600 text-lg">
        Brindamos atención médica integral con los más altos estándares de calidad.
      </p>
      <div class="w-16 h-1 mx-auto mt-6" style={`background-color: var(--color-secundario)`}></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {servicios.map((servicio) => (
        <div class="flex gap-6 p-6 border border-gray-100 hover:border-gray-200 transition-colors duration-300">
          <div class="w-14 h-14 shrink-0 flex items-center justify-center" style={`color: var(--color-secundario)`}>
            <Icon name={servicio.icono} size={32} />
          </div>
          <div>
            <h3 class="text-xl font-bold mb-2" style={`color: var(--color-primario)`}>
              {servicio.nombre}
            </h3>
            <p class="text-gray-600 leading-relaxed">
              {servicio.descripcion}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
