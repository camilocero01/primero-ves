---
/**
 * RUTA DINÁMICA: /{doctor-slug}/{plantilla}
 * Genera todas las combinaciones de doctor × plantilla en build time.
 */
import type { GetStaticPaths } from 'astro';
import { doctores, plantillas, type DoctorConfig, type Plantilla } from '../../config/siteConfig';

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';

// Elegante
import HeroElegante from '../../components/elegante/HeroElegante.astro';
import ServiciosElegante from '../../components/elegante/ServiciosElegante.astro';
import GaleriaElegante from '../../components/elegante/GaleriaElegante.astro';
import SobreMiElegante from '../../components/elegante/SobreMiElegante.astro';
import InstalacionesElegante from '../../components/elegante/InstalacionesElegante.astro';
import TestimoniosElegante from '../../components/elegante/TestimoniosElegante.astro';
import ContactoElegante from '../../components/elegante/ContactoElegante.astro';

// Moderna
import HeroModerna from '../../components/moderna/HeroModerna.astro';
import ServiciosModerna from '../../components/moderna/ServiciosModerna.astro';
import GaleriaModerna from '../../components/moderna/GaleriaModerna.astro';
import SobreMiModerna from '../../components/moderna/SobreMiModerna.astro';
import InstalacionesModerna from '../../components/moderna/InstalacionesModerna.astro';
import TestimoniosModerna from '../../components/moderna/TestimoniosModerna.astro';
import ContactoModerna from '../../components/moderna/ContactoModerna.astro';

// Clásica
import HeroClasica from '../../components/clasica/HeroClasica.astro';
import ServiciosClasica from '../../components/clasica/ServiciosClasica.astro';
import GaleriaClasica from '../../components/clasica/GaleriaClasica.astro';
import SobreMiClasica from '../../components/clasica/SobreMiClasica.astro';
import InstalacionesClasica from '../../components/clasica/InstalacionesClasica.astro';
import TestimoniosClasica from '../../components/clasica/TestimoniosClasica.astro';
import ContactoClasica from '../../components/clasica/ContactoClasica.astro';

// Minimalista
import HeroMinimalista from '../../components/minimalista/HeroMinimalista.astro';
import ServiciosMinimalista from '../../components/minimalista/ServiciosMinimalista.astro';
import GaleriaMinimalista from '../../components/minimalista/GaleriaMinimalista.astro';
import SobreMiMinimalista from '../../components/minimalista/SobreMiMinimalista.astro';
import InstalacionesMinimalista from '../../components/minimalista/InstalacionesMinimalista.astro';
import TestimoniosMinimalista from '../../components/minimalista/TestimoniosMinimalista.astro';
import ContactoMinimalista from '../../components/minimalista/ContactoMinimalista.astro';

// Premium
import HeroPremium from '../../components/premium/HeroPremium.astro';
import ServiciosPremium from '../../components/premium/ServiciosPremium.astro';
import GaleriaPremium from '../../components/premium/GaleriaPremium.astro';
import SobreMiPremium from '../../components/premium/SobreMiPremium.astro';
import InstalacionesPremium from '../../components/premium/InstalacionesPremium.astro';
import TestimoniosPremium from '../../components/premium/TestimoniosPremium.astro';
import ContactoPremium from '../../components/premium/ContactoPremium.astro';

// Vanguardia
import HeroVanguardia from '../../components/vanguardia/HeroVanguardia.astro';
import ServiciosVanguardia from '../../components/vanguardia/ServiciosVanguardia.astro';
import GaleriaVanguardia from '../../components/vanguardia/GaleriaVanguardia.astro';
import SobreMiVanguardia from '../../components/vanguardia/SobreMiVanguardia.astro';
import InstalacionesVanguardia from '../../components/vanguardia/InstalacionesVanguardia.astro';
import TestimoniosVanguardia from '../../components/vanguardia/TestimoniosVanguardia.astro';
import ContactoVanguardia from '../../components/vanguardia/ContactoVanguardia.astro';

export const getStaticPaths: GetStaticPaths = () => {
  const paths = [];
  for (const doc of doctores) {
    for (const plantilla of plantillas) {
      paths.push({
        params: { doctor: doc.slug, plantilla },
        props: { config: doc, plantilla },
      });
    }
  }
  return paths;
};

interface Props {
  config: DoctorConfig;
  plantilla: Plantilla;
}

const { config, plantilla } = Astro.props;
---

<BaseLayout config={config}>
  <Header config={config} slug={config.slug} plantilla={plantilla} />
  <main>
    {plantilla === 'elegante' && (
      <>
        <HeroElegante config={config} />
        <ServiciosElegante config={config} />
        <GaleriaElegante config={config} />
        <SobreMiElegante config={config} />
        <InstalacionesElegante config={config} />
        <TestimoniosElegante config={config} />
        <ContactoElegante config={config} />
      </>
    )}
    {plantilla === 'moderna' && (
      <>
        <HeroModerna config={config} />
        <ServiciosModerna config={config} />
        <GaleriaModerna config={config} />
        <SobreMiModerna config={config} />
        <InstalacionesModerna config={config} />
        <TestimoniosModerna config={config} />
        <ContactoModerna config={config} />
      </>
    )}
    {plantilla === 'clasica' && (
      <>
        <HeroClasica config={config} />
        <ServiciosClasica config={config} />
        <GaleriaClasica config={config} />
        <SobreMiClasica config={config} />
        <InstalacionesClasica config={config} />
        <TestimoniosClasica config={config} />
        <ContactoClasica config={config} />
      </>
    )}
    {plantilla === 'minimalista' && (
      <>
        <HeroMinimalista config={config} />
        <ServiciosMinimalista config={config} />
        <GaleriaMinimalista config={config} />
        <SobreMiMinimalista config={config} />
        <InstalacionesMinimalista config={config} />
        <TestimoniosMinimalista config={config} />
        <ContactoMinimalista config={config} />
      </>
    )}
    {plantilla === 'premium' && (
      <>
        <HeroPremium config={config} />
        <ServiciosPremium config={config} />
        <GaleriaPremium config={config} />
        <SobreMiPremium config={config} />
        <InstalacionesPremium config={config} />
        <TestimoniosPremium config={config} />
        <ContactoPremium config={config} />
      </>
    )}
    {plantilla === 'vanguardia' && (
      <>
        <HeroVanguardia config={config} />
        <ServiciosVanguardia config={config} />
        <GaleriaVanguardia config={config} />
        <SobreMiVanguardia config={config} />
        <InstalacionesVanguardia config={config} />
        <TestimoniosVanguardia config={config} />
        <ContactoVanguardia config={config} />
      </>
    )}
  </main>
  <Footer config={config} slug={config.slug} plantilla={plantilla} />
  <WhatsAppFloat config={config} />
</BaseLayout>
