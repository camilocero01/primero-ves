---
/**
 * PRIMEROVES - Página Principal
 * Muestra las 3 plantillas para un doctor específico vía query param: ?doctor=slug
 * Si no se pasa parámetro, muestra doctores de muestra con tabs.
 * Si se pasa un slug de un doctor que NO es de muestra, oculta la sección demo.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { doctores, plantillas } from '../config/siteConfig';

const demoSlugs = ['dr-carlos-mendoza', 'dra-sofia-herrera', 'dr-alejandro-ruiz'];
const demoDoctores = doctores.filter(d => demoSlugs.includes(d.slug));

const plantillaInfo: Record<string, { label: string; badge: string; badgeColor: string; desc: string }> = {
  elegante: { label: 'Elegante', badge: 'Popular', badgeColor: 'amber', desc: 'Sofisticada y con prestigio' },
  moderna:  { label: 'Moderna',  badge: 'Bold',    badgeColor: 'blue',  desc: 'Audaz e innovadora' },
  clasica:  { label: 'Clásica',  badge: 'Sobria',  badgeColor: 'green', desc: 'Tradicional y sólida' },
};
---

<BaseLayout
  title="PrimeroVes | Tu sitio web médico, primero lo ves, luego decides"
  description="Diseñamos sitios web profesionales para médicos especialistas. Primero ves tu sitio terminado, luego decides si lo quieres. Sin riesgo."
>
  <div class="min-h-screen bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white">

    <!-- ═══════ NAVBAR ═══════ -->
    <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-slate-900/0">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 md:h-20">
          <!-- Logo -->
          <a href="#" class="flex items-center gap-2.5 group shrink-0">
            <div class="w-9 h-9 rounded-lg bg-amber-400 flex items-center justify-center">
              <span class="text-slate-900 font-bold text-lg font-heading leading-none">P</span>
            </div>
            <span class="text-xl font-bold text-white tracking-tight">
              Primero<span class="text-amber-400">Ves</span>
            </span>
          </a>

          <!-- Links desktop -->
          <div class="hidden md:flex items-center gap-8">
            <a href="#como-funciona" class="text-white/60 hover:text-white text-sm font-medium transition-colors">Cómo funciona</a>
            <a href="#comparativo" class="text-white/60 hover:text-white text-sm font-medium transition-colors">Comparativo</a>
            <a href="#precio" class="text-white/60 hover:text-white text-sm font-medium transition-colors">Precio</a>
            <a href="#servicios-adicionales" class="text-white/60 hover:text-white text-sm font-medium transition-colors">Servicios</a>
            <a href="https://wa.me/573001234567?text=Hola%2C%20me%20interesa%20un%20sitio%20web%20para%20mi%20consultorio" 
               target="_blank"
               class="inline-flex items-center gap-2 bg-amber-400 hover:bg-amber-500 text-slate-900 font-semibold px-5 py-2.5 rounded-full text-sm transition-all duration-300 hover:shadow-lg hover:shadow-amber-400/20">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
              Contáctanos
            </a>
          </div>

          <!-- Hamburger mobile -->
          <button id="menu-toggle" class="md:hidden relative w-10 h-10 flex items-center justify-center rounded-lg hover:bg-white/10 transition-colors" aria-label="Menú">
            <div class="flex flex-col gap-1.5" id="hamburger-icon">
              <span class="block w-5 h-0.5 bg-white rounded-full transition-all duration-300 origin-center" id="bar1"></span>
              <span class="block w-5 h-0.5 bg-white rounded-full transition-all duration-300" id="bar2"></span>
              <span class="block w-5 h-0.5 bg-white rounded-full transition-all duration-300 origin-center" id="bar3"></span>
            </div>
          </button>
        </div>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="md:hidden overflow-hidden transition-all duration-300" style="max-height: 0; opacity: 0;">
        <div class="px-4 pb-6 pt-2 space-y-1 bg-slate-900/95 backdrop-blur-lg border-t border-white/5">
          <a href="#como-funciona" class="mobile-link block px-4 py-3 text-white/70 hover:text-white hover:bg-white/5 rounded-lg text-sm font-medium transition-colors">Cómo funciona</a>
          <a href="#comparativo" class="mobile-link block px-4 py-3 text-white/70 hover:text-white hover:bg-white/5 rounded-lg text-sm font-medium transition-colors">Comparativo</a>
          <a href="#precio" class="mobile-link block px-4 py-3 text-white/70 hover:text-white hover:bg-white/5 rounded-lg text-sm font-medium transition-colors">Precio</a>
          <a href="#servicios-adicionales" class="mobile-link block px-4 py-3 text-white/70 hover:text-white hover:bg-white/5 rounded-lg text-sm font-medium transition-colors">Servicios</a>
          <div class="pt-3">
            <a href="https://wa.me/573001234567?text=Hola%2C%20me%20interesa%20un%20sitio%20web%20para%20mi%20consultorio" 
               target="_blank"
               class="flex items-center justify-center gap-2 bg-amber-400 hover:bg-amber-500 text-slate-900 font-semibold px-5 py-3 rounded-full text-sm transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
              Contáctanos
            </a>
          </div>
        </div>
      </div>
    </nav>

    <!-- ═══════ HERO ═══════ -->
    <header class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 md:pt-40 pb-20 text-center">
      <!-- Decorative blobs -->
      <div class="absolute top-20 left-1/4 w-72 h-72 bg-amber-400/5 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-blue-400/5 rounded-full blur-3xl pointer-events-none"></div>

      <div class="relative">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 rounded-full text-sm mb-8 border border-white/10 backdrop-blur-sm">
          <div class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></div>
          <span class="text-white/80">Diseño web para médicos especialistas xxx</span>
        </div>

        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold mb-6 leading-tight">
          Tu sitio web médico.<br>
          <span class="text-amber-400">Primero lo ves.</span>
        </h1>
        
        <p class="text-xl md:text-2xl text-white/50 max-w-2xl mx-auto mb-4 font-light">
          Diseñamos tu sitio web profesional con tu información real.
        </p>
        <p class="text-lg text-white/30 max-w-xl mx-auto mb-12">
          Lo ves terminado. Si te gusta, lo activas. Si no, no pagas nada.
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
          <a href="https://wa.me/573001234567?text=Hola%2C%20me%20interesa%20un%20sitio%20web%20para%20mi%20consultorio" 
             target="_blank"
             class="inline-flex items-center gap-3 bg-amber-400 hover:bg-amber-500 text-slate-900 font-bold px-8 py-4 rounded-full transition-all duration-300 hover:shadow-xl hover:shadow-amber-400/20 hover:-translate-y-0.5 text-lg">
            Quiero ver mi sitio gratis
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a href="#como-funciona" class="inline-flex items-center gap-2 text-white/60 hover:text-white font-medium px-6 py-4 rounded-full transition-colors text-lg">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"/></svg>
            ¿Cómo funciona?
          </a>
        </div>

        <!-- Trust badges -->
        <div class="flex flex-wrap items-center justify-center gap-6 md:gap-10 text-white/30 text-sm">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            <span>Sin riesgo</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span>Entrega en 24-48h</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
            <span>Sin anticipo</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Contenido principal -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">

      <!-- ═══════ VISTA DOCTOR PERSONALIZADO (slug NO demo) ═══════ -->
      {doctores.map((doc) => (
        <div class="doctor-section" style="display:none" data-slug={doc.slug} data-demo={demoSlugs.includes(doc.slug) ? 'true' : 'false'}>
          <!-- Saludo personalizado -->
          <div class="text-center mb-12">
            <div class="inline-flex items-center gap-4 mb-6">
              <div class="w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold shrink-0"
                   style={`background-color: ${doc.colores.primario}; color: ${doc.colores.secundario};`}>
                {doc.doctor.nombre.split(' ').map((w: string) => w[0]).slice(0, 2).join('')}
              </div>
              <div class="text-left">
                <h2 class="text-2xl font-bold text-white">{doc.doctor.nombre}</h2>
                <p style={`color: ${doc.colores.secundario};`}>{doc.doctor.especialidad}</p>
              </div>
            </div>
            <p class="text-white/50 max-w-lg mx-auto">
              Hemos preparado 3 propuestas de diseño para su sitio web profesional. 
              Elija la que más le guste para verla en detalle.
            </p>
          </div>

          <!-- Las 3 plantillas -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {plantillas.map((p) => {
              const info = plantillaInfo[p];
              return (
                <a href={`/${doc.slug}/${p}`} class="group block">
                  <div class="bg-white/5 border border-white/10 rounded-2xl overflow-hidden hover:border-amber-400/50 transition-all duration-500 hover:shadow-2xl hover:shadow-amber-400/10 hover:-translate-y-2">
                    <!-- Preview visual -->
                    <div class="aspect-video flex items-center justify-center p-8 relative overflow-hidden"
                         style={`background: linear-gradient(135deg, ${doc.colores.primario}, ${doc.colores.primario}dd);`}>
                      {p === 'elegante' && (
                        <div class="text-center">
                          <p style={`color: ${doc.colores.secundario};`} class="text-sm tracking-widest uppercase mb-2">{doc.doctor.especialidad}</p>
                          <h3 class="text-3xl font-bold text-white font-heading">{doc.doctor.nombre}</h3>
                          <p class="text-white/50 mt-2 italic text-sm">"{doc.doctor.frase}"</p>
                        </div>
                      )}
                      {p === 'moderna' && (
                        <Fragment>
                          <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle, rgba(255,255,255,0.2) 1px, transparent 1px); background-size: 20px 20px;"></div>
                          <div class="text-center relative">
                            <h3 class="text-4xl font-bold text-white">{doc.doctor.nombre.split(' ').slice(0, 2).join(' ')}</h3>
                            <p style={`color: ${doc.colores.secundario};`} class="text-xl font-bold mt-1">{doc.doctor.nombre.split(' ').slice(2).join(' ')}</p>
                            <div class="w-2 h-2 rounded-full bg-green-400 animate-pulse mx-auto mt-3"></div>
                          </div>
                        </Fragment>
                      )}
                      {p === 'clasica' && (
                        <div class="flex items-stretch w-full h-full absolute inset-0">
                          <div class="w-1/2 bg-white flex items-center justify-center p-4">
                            <div>
                              <div class="w-8 h-0.5 mb-3" style={`background-color: ${doc.colores.secundario};`}></div>
                              <p class="text-xs tracking-widest uppercase" style={`color: ${doc.colores.primario};`}>{doc.doctor.especialidad}</p>
                              <p class="text-lg font-bold mt-1" style={`color: ${doc.colores.primario};`}>{doc.doctor.nombre}</p>
                            </div>
                          </div>
                          <div class="w-1/2 bg-gradient-to-br from-gray-300 to-gray-400"></div>
                        </div>
                      )}
                    </div>
                    <!-- Info -->
                    <div class="p-6">
                      <div class="flex items-center justify-between mb-3">
                        <h3 class="text-xl font-bold text-white group-hover:text-amber-400 transition-colors">
                          {info.label}
                        </h3>
                        <span class={`text-xs px-3 py-1 rounded-full bg-${info.badgeColor}-400/20 text-${info.badgeColor}-400`}>
                          {info.badge}
                        </span>
                      </div>
                      <p class="text-white/50 text-sm">{info.desc}</p>
                      <div class="mt-4 flex items-center gap-2 text-sm font-medium text-amber-400/80 group-hover:text-amber-400 transition-colors">
                        <span>Ver esta propuesta</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                        </svg>
                      </div>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      ))}

      <!-- ═══════ SECCIÓN DEMO: Páginas de muestra ═══════ -->
      <div id="demo-showcase" class="mb-16">
        <!-- Título y badge -->
        <div class="text-center mb-10">
          <span class="inline-block px-4 py-1.5 bg-amber-400/10 text-amber-400 text-sm font-semibold rounded-full mb-6 border border-amber-400/20">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 inline -mt-0.5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            Páginas de muestra
          </span>
          <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">
            Mira cómo quedaría <span class="text-amber-400">tu sitio web</span>
          </h2>
          <p class="text-white/40 max-w-2xl mx-auto text-lg">
            Estos son ejemplos reales de sitios web que creamos. Cada uno tiene 3 diseños diferentes. Explora y elige el estilo que más te guste.
          </p>
        </div>

        <!-- Tabs de doctores demo -->
        <div class="flex flex-wrap items-center justify-center gap-3 mb-10">
          {demoDoctores.map((doc, idx) => (
            <button
              class="demo-tab flex items-center gap-3 px-5 py-3 rounded-full border transition-all duration-300 cursor-pointer"
              data-demo-slug={doc.slug}
              style={idx === 0 ? `background-color: ${doc.colores.primario}; border-color: ${doc.colores.primario}; color: white;` : ''}
            >
              <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold shrink-0"
                   style={`background-color: ${doc.colores.secundario}; color: ${doc.colores.primario};`}>
                {doc.doctor.nombre.split(' ').map((w: string) => w[0]).slice(0, 2).join('')}
              </div>
              <div class="text-left">
                <span class="block text-sm font-semibold leading-tight">{doc.doctor.titulo} {doc.doctor.nombre.split(' ')[0]}</span>
                <span class="block text-xs opacity-70 leading-tight">{doc.doctor.especialidad}</span>
              </div>
            </button>
          ))}
        </div>

        <!-- Contenido de cada doctor demo (preview de 3 plantillas) -->
        {demoDoctores.map((doc, idx) => (
          <div class="demo-doctor-content" data-demo-slug={doc.slug} style={idx === 0 ? '' : 'display:none'}>
            <!-- Info del doctor -->
            <div class="text-center mb-8">
              <div class="inline-flex items-center gap-3 px-5 py-2.5 bg-white/5 rounded-full border border-white/10 mb-3">
                <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold shrink-0"
                     style={`background-color: ${doc.colores.primario}; color: ${doc.colores.secundario};`}>
                  {doc.doctor.nombre.split(' ').map((w: string) => w[0]).slice(0, 2).join('')}
                </div>
                <div class="text-left">
                  <span class="block text-white font-semibold text-sm">{doc.doctor.titulo} {doc.doctor.nombre}</span>
                  <span class="block text-xs" style={`color: ${doc.colores.secundario};`}>{doc.doctor.especialidad} · {doc.contacto.ciudad}</span>
                </div>
                <span class="ml-2 px-2 py-0.5 bg-amber-400/10 text-amber-400 text-[10px] font-bold rounded-full border border-amber-400/20 uppercase tracking-wider">
                  Ejemplo
                </span>
              </div>
            </div>

            <!-- Las 3 plantillas -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              {plantillas.map((p) => {
                const info = plantillaInfo[p];
                return (
                  <a href={`/${doc.slug}/${p}`} class="group block">
                    <div class="bg-white/5 border border-white/10 rounded-2xl overflow-hidden hover:border-amber-400/50 transition-all duration-500 hover:shadow-2xl hover:shadow-amber-400/10 hover:-translate-y-2">
                      <!-- Preview visual -->
                      <div class="aspect-video flex items-center justify-center p-8 relative overflow-hidden"
                           style={`background: linear-gradient(135deg, ${doc.colores.primario}, ${doc.colores.primario}dd);`}>
                        {p === 'elegante' && (
                          <div class="text-center">
                            <p style={`color: ${doc.colores.secundario};`} class="text-sm tracking-widest uppercase mb-2">{doc.doctor.especialidad}</p>
                            <h3 class="text-3xl font-bold text-white font-heading">{doc.doctor.nombre}</h3>
                            <p class="text-white/50 mt-2 italic text-sm">"{doc.doctor.frase}"</p>
                          </div>
                        )}
                        {p === 'moderna' && (
                          <Fragment>
                            <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle, rgba(255,255,255,0.2) 1px, transparent 1px); background-size: 20px 20px;"></div>
                            <div class="text-center relative">
                              <h3 class="text-4xl font-bold text-white">{doc.doctor.nombre.split(' ').slice(0, 2).join(' ')}</h3>
                              <p style={`color: ${doc.colores.secundario};`} class="text-xl font-bold mt-1">{doc.doctor.nombre.split(' ').slice(2).join(' ')}</p>
                              <div class="w-2 h-2 rounded-full bg-green-400 animate-pulse mx-auto mt-3"></div>
                            </div>
                          </Fragment>
                        )}
                        {p === 'clasica' && (
                          <div class="flex items-stretch w-full h-full absolute inset-0">
                            <div class="w-1/2 bg-white flex items-center justify-center p-4">
                              <div>
                                <div class="w-8 h-0.5 mb-3" style={`background-color: ${doc.colores.secundario};`}></div>
                                <p class="text-xs tracking-widest uppercase" style={`color: ${doc.colores.primario};`}>{doc.doctor.especialidad}</p>
                                <p class="text-lg font-bold mt-1" style={`color: ${doc.colores.primario};`}>{doc.doctor.nombre}</p>
                              </div>
                            </div>
                            <div class="w-1/2 bg-gradient-to-br from-gray-300 to-gray-400"></div>
                          </div>
                        )}
                      </div>
                      <!-- Info -->
                      <div class="p-6">
                        <div class="flex items-center justify-between mb-3">
                          <h3 class="text-xl font-bold text-white group-hover:text-amber-400 transition-colors">
                            {info.label}
                          </h3>
                          <span class={`text-xs px-3 py-1 rounded-full bg-${info.badgeColor}-400/20 text-${info.badgeColor}-400`}>
                            {info.badge}
                          </span>
                        </div>
                        <p class="text-white/50 text-sm">{info.desc}</p>
