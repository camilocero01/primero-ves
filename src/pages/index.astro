---
/**
 * PRIMEROVES - Página Principal
 * Selector de plantillas para demostración y vista previa.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="PrimeroVes | Tu sitio web médico, primero lo ves, luego decides"
  description="Diseñamos sitios web profesionales para médicos especialistas. Primero ves tu sitio terminado, luego decides si lo quieres. Sin riesgo."
>
  <div class="min-h-screen bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white">
    <!-- Hero -->
    <header class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-16 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 rounded-full text-sm mb-8 border border-white/10">
        <div class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></div>
        <span class="text-white/80">Plataforma en desarrollo</span>
      </div>

      <h1 class="text-5xl md:text-7xl font-bold mb-6">
        Primero<span class="text-amber-400">Ves</span>
      </h1>
      
      <p class="text-xl md:text-2xl text-white/60 max-w-2xl mx-auto mb-4 font-light">
        Tu sitio web médico profesional.
      </p>
      <p class="text-lg text-white/40 max-w-xl mx-auto mb-12">
        Primero ves tu sitio terminado. Luego decides si lo quieres. Sin riesgo.
      </p>
    </header>

    <!-- Selector de plantillas -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
      <h2 class="text-2xl font-bold text-center mb-12 text-white/80">
        Elige una plantilla para previsualizar
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Plantilla Elegante -->
        <a href="/elegante" class="group block">
          <div class="bg-white/5 border border-white/10 rounded-2xl overflow-hidden hover:border-amber-400/50 transition-all duration-500 hover:shadow-2xl hover:shadow-amber-400/10 hover:-translate-y-2">
            <div class="aspect-video bg-gradient-to-br from-[#1B4D6E] to-[#1B4D6E]/80 flex items-center justify-center p-8">
              <div class="text-center">
                <p class="text-[#C9A96E] text-sm tracking-widest uppercase mb-2">Especialidad</p>
                <h3 class="text-3xl font-bold text-white font-heading">Dr. Nombre</h3>
                <p class="text-white/50 mt-2 italic">"Tu frase aquí"</p>
              </div>
            </div>
            <div class="p-6">
              <div class="flex items-center justify-between mb-3">
                <h3 class="text-xl font-bold text-white group-hover:text-amber-400 transition-colors">
                  Elegante
                </h3>
                <span class="text-xs px-3 py-1 bg-amber-400/20 text-amber-400 rounded-full">Popular</span>
              </div>
              <p class="text-white/50 text-sm">
                Diseño sofisticado con tipografía serif y líneas limpias. Ideal para transmitir experiencia y prestigio.
              </p>
            </div>
          </div>
        </a>

        <!-- Plantilla Moderna -->
        <a href="/moderna" class="group block">
          <div class="bg-white/5 border border-white/10 rounded-2xl overflow-hidden hover:border-amber-400/50 transition-all duration-500 hover:shadow-2xl hover:shadow-amber-400/10 hover:-translate-y-2">
            <div class="aspect-video bg-gradient-to-br from-[#1B4D6E] to-[#0D2B3E] flex items-center justify-center p-8 relative overflow-hidden">
              <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle, rgba(255,255,255,0.2) 1px, transparent 1px); background-size: 20px 20px;"></div>
              <div class="text-center relative">
                <h3 class="text-4xl font-bold text-white">Dr.</h3>
                <p class="text-[#C9A96E] text-2xl font-bold">Nombre</p>
                <div class="w-2 h-2 rounded-full bg-green-400 animate-pulse mx-auto mt-3"></div>
              </div>
            </div>
            <div class="p-6">
              <div class="flex items-center justify-between mb-3">
                <h3 class="text-xl font-bold text-white group-hover:text-amber-400 transition-colors">
                  Moderna
                </h3>
                <span class="text-xs px-3 py-1 bg-blue-400/20 text-blue-400 rounded-full">Bold</span>
              </div>
              <p class="text-white/50 text-sm">
                Diseño audaz con colores vibrantes y alto impacto visual. Para médicos innovadores.
              </p>
            </div>
          </div>
        </a>

        <!-- Plantilla Clásica -->
        <a href="/clasica" class="group block">
          <div class="bg-white/5 border border-white/10 rounded-2xl overflow-hidden hover:border-amber-400/50 transition-all duration-500 hover:shadow-2xl hover:shadow-amber-400/10 hover:-translate-y-2">
            <div class="aspect-video flex items-stretch">
              <div class="w-1/2 bg-white flex items-center justify-center p-4">
                <div>
                  <div class="w-8 h-0.5 bg-[#C9A96E] mb-3"></div>
                  <p class="text-[#1B4D6E] text-xs tracking-widest uppercase">Especialidad</p>
                  <p class="text-[#1B4D6E] text-lg font-bold mt-1">Dr. Nombre</p>
                </div>
              </div>
              <div class="w-1/2 bg-gradient-to-br from-gray-300 to-gray-400"></div>
            </div>
            <div class="p-6">
              <div class="flex items-center justify-between mb-3">
                <h3 class="text-xl font-bold text-white group-hover:text-amber-400 transition-colors">
                  Clásica
                </h3>
                <span class="text-xs px-3 py-1 bg-green-400/20 text-green-400 rounded-full">Sobria</span>
              </div>
              <p class="text-white/50 text-sm">
                Diseño tradicional split 50/50, transmite solidez y trayectoria. Para especialistas consolidados.
              </p>
            </div>
          </div>
        </a>
      </div>

      <!-- Info -->
      <div class="mt-20 text-center">
        <p class="text-white/30 text-sm">
          Todas las plantillas son 100% personalizables: colores, textos, servicios, horarios y más.
        </p>
        <p class="text-white/20 text-xs mt-2">
          Datos de ejemplo. No representan a un médico real.
        </p>
      </div>
    </main>

    <!-- Footer -->
    <footer class="border-t border-white/5 py-8 text-center">
      <p class="text-white/20 text-sm">
        &copy; {new Date().getFullYear()} PrimeroVes. Todos los derechos reservados.
      </p>
    </footer>
  </div>
</BaseLayout>
