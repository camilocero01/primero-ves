  <!-- Script: navbar + mobile menu + doctor query param + demo tabs -->
  <script is:inline>
    (function () {
      var demoSlugs = ['dr-carlos-mendoza', 'dra-sofia-herrera', 'dr-alejandro-ruiz'];

      // ─── Doctor query param ───
      var params = new URLSearchParams(window.location.search);
      var doctorSlug = params.get('doctor');

      if (doctorSlug && demoSlugs.indexOf(doctorSlug) === -1) {
        // Doctor NO es de muestra → ocultar demo showcase, mostrar su sección personalizada
        var demoShowcase = document.getElementById('demo-showcase');
        if (demoShowcase) demoShowcase.style.display = 'none';

        var target = document.querySelector('.doctor-section[data-slug="' + doctorSlug + '"]');
        if (target) {
          target.style.display = 'block';
        }
      }

      // ─── Demo tabs logic ───
      var tabs = document.querySelectorAll('.demo-tab');
      var contents = document.querySelectorAll('.demo-doctor-content');

      function activateDemo(slug) {
        // Update tabs
        for (var i = 0; i < tabs.length; i++) {
          var tab = tabs[i];
          var tabSlug = tab.getAttribute('data-demo-slug');
          if (tabSlug === slug) {
            // Find doctor colors from the content section
            tab.style.backgroundColor = '';
            tab.style.borderColor = '';
            tab.style.color = 'white';
            tab.classList.add('demo-tab-active');
            tab.classList.remove('border-white/10', 'text-white/60');
          } else {
            tab.style.backgroundColor = 'transparent';
            tab.style.borderColor = 'rgba(255,255,255,0.1)';
            tab.style.color = 'rgba(255,255,255,0.6)';
            tab.classList.remove('demo-tab-active');
            tab.classList.add('border-white/10', 'text-white/60');
          }
        }
        // Update content
        for (var j = 0; j < contents.length; j++) {
          var content = contents[j];
          if (content.getAttribute('data-demo-slug') === slug) {
            content.style.display = 'block';
          } else {
            content.style.display = 'none';
          }
        }
      }

      // Attach click handlers
      for (var k = 0; k < tabs.length; k++) {
        (function(tab) {
          tab.addEventListener('click', function () {
            activateDemo(tab.getAttribute('data-demo-slug'));
          });
        })(tabs[k]);
      }

      // ─── Navbar scroll effect ───
      var navbar = document.getElementById('navbar');
      var scrolled = false;

      function onScroll() {
        var isScrolled = window.scrollY > 20;
        if (isScrolled !== scrolled) {
          scrolled = isScrolled;
          if (scrolled) {
            navbar.style.backgroundColor = 'rgba(15, 23, 42, 0.95)';
            navbar.style.backdropFilter = 'blur(12px)';
            navbar.style.borderBottom = '1px solid rgba(255,255,255,0.05)';
            navbar.style.boxShadow = '0 4px 30px rgba(0,0,0,0.3)';
          } else {
            navbar.style.backgroundColor = 'transparent';
            navbar.style.backdropFilter = 'none';
            navbar.style.borderBottom = 'none';
            navbar.style.boxShadow = 'none';
          }
        }
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      // ─── Mobile menu toggle ───
      var toggle = document.getElementById('menu-toggle');
      var mobileMenu = document.getElementById('mobile-menu');
      var bar1 = document.getElementById('bar1');
      var bar2 = document.getElementById('bar2');
      var bar3 = document.getElementById('bar3');
      var isOpen = false;

      if (toggle && mobileMenu) {
        toggle.addEventListener('click', function () {
          isOpen = !isOpen;
          if (isOpen) {
            mobileMenu.style.maxHeight = '400px';
            mobileMenu.style.opacity = '1';
            bar1.style.transform = 'translateY(4px) rotate(45deg)';
            bar2.style.opacity = '0';
            bar3.style.transform = 'translateY(-4px) rotate(-45deg)';
          } else {
            mobileMenu.style.maxHeight = '0';
            mobileMenu.style.opacity = '0';
            bar1.style.transform = 'none';
            bar2.style.opacity = '1';
            bar3.style.transform = 'none';
          }
        });

        // Close menu on link click
        var mobileLinks = mobileMenu.querySelectorAll('.mobile-link');
        for (var i = 0; i < mobileLinks.length; i++) {
          mobileLinks[i].addEventListener('click', function () {
            isOpen = false;
            mobileMenu.style.maxHeight = '0';
            mobileMenu.style.opacity = '0';
            bar1.style.transform = 'none';
            bar2.style.opacity = '1';
            bar3.style.transform = 'none';
          });
        }
      }
      // ─── Cotizador interactivo ───
      var PLAN_BASE = 400000;
      var DESCUENTO = 0.15; // 15% descuento lanzamiento en servicios adicionales
      var cotizadorItems = document.querySelectorAll('.cotizador-item');
      var selectedServices = {};

      function formatCOP(n) {
        return '$' + n.toLocaleString('es-CO');
      }

      function updateCotizador() {
        var adicionales = 0;
        var nombres = [];
        for (var key in selectedServices) {
          if (selectedServices[key]) {
            var item = document.querySelector('.cotizador-item[data-name="' + key + '"]');
            if (item) {
              adicionales += parseInt(item.getAttribute('data-price'));
              nombres.push(key);
            }
          }
        }

        var descuento = Math.round(adicionales * DESCUENTO);
        var totalSinDcto = PLAN_BASE + adicionales;
        var total = PLAN_BASE + adicionales - descuento;

        var adRow = document.getElementById('cotizador-adicionales-row');
        var dctoRow = document.getElementById('cotizador-descuento-row');
        var sinDcto = document.getElementById('cotizador-sin-dcto');

        document.getElementById('cotizador-adicionales').textContent = formatCOP(adicionales);
        document.getElementById('cotizador-descuento').textContent = '-' + formatCOP(descuento);
        document.getElementById('cotizador-total').textContent = formatCOP(total);

        if (adicionales > 0) {
          adRow.style.display = 'flex';
          dctoRow.style.display = 'flex';
          sinDcto.style.display = 'inline';
          sinDcto.textContent = formatCOP(totalSinDcto);
        } else {
          adRow.style.display = 'none';
          dctoRow.style.display = 'none';
          sinDcto.style.display = 'none';
        }

        // Update lista de servicios
        var lista = document.getElementById('cotizador-servicios-lista');
        if (nombres.length > 0) {
          lista.textContent = 'Incluye: Plan base + ' + nombres.join(' + ');
        } else {
          lista.textContent = '';
        }

        // Update WhatsApp CTA link
        var msg = 'Hola, quiero cotizar mi sitio web con PrimeroVes.\n\n';
        msg += '• Plan base: $400.000\n';
        if (nombres.length > 0) {
          for (var i = 0; i < nombres.length; i++) {
            var it = document.querySelector('.cotizador-item[data-name="' + nombres[i] + '"]');
            msg += '• ' + nombres[i] + ': ' + formatCOP(parseInt(it.getAttribute('data-price'))) + '\n';
          }
          msg += '\nSubtotal servicios adicionales: ' + formatCOP(adicionales);
          msg += '\nDcto. lanzamiento (15%): -' + formatCOP(descuento);
          msg += '\n\nTotal: ' + formatCOP(total) + ' COP';
        } else {
          msg += '\nTotal: $400.000 COP';
        }

        var cta = document.getElementById('cotizador-cta');
        cta.href = 'https://wa.me/573001234567?text=' + encodeURIComponent(msg);
      }

      for (var c = 0; c < cotizadorItems.length; c++) {
        (function (item) {
          item.addEventListener('click', function () {
            var name = item.getAttribute('data-name');
            var isActive = !!selectedServices[name];
            selectedServices[name] = !isActive;

            var checkBox = item.querySelector('.cotizador-check');
            var checkSvg = checkBox.querySelector('svg');

            if (selectedServices[name]) {
              checkBox.style.backgroundColor = '#fbbf24';
              checkBox.style.borderColor = '#fbbf24';
              checkSvg.style.opacity = '1';
              item.style.borderColor = 'rgba(251, 191, 36, 0.3)';
              item.style.backgroundColor = 'rgba(251, 191, 36, 0.05)';
            } else {
              checkBox.style.backgroundColor = 'transparent';
              checkBox.style.borderColor = 'rgba(255,255,255,0.2)';
              checkSvg.style.opacity = '0';
              item.style.borderColor = 'rgba(255,255,255,0.1)';
              item.style.backgroundColor = 'rgba(255,255,255,0.05)';
            }

            updateCotizador();
          });
        })(cotizadorItems[c]);
      }

    })();
  </script>
</BaseLayout>
