---
import '../styles/global.css';
import type { DoctorConfig } from '../config/siteConfig';

interface Props {
  config?: DoctorConfig;
  title?: string;
  description?: string;
}

const { config, title: titleProp, description: descProp } = Astro.props;

// Si no hay config (ej: página index), usar defaults
const title = titleProp ?? config?.seo.title ?? 'PrimeroVes';
const description = descProp ?? config?.seo.description ?? '';

const seo = config?.seo;
const doctor = config?.doctor;
const colores = config?.colores ?? { primario: '#1B4D6E', secundario: '#C9A96E' };
const contacto = config?.contacto;
const horarios = config?.horarios ?? [];
const servicios = config?.servicios ?? [];
---

<!doctype html>
<html lang={seo?.locale?.replace('_', '-') ?? 'es'} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- SEO Básico -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {seo && <meta name="keywords" content={seo.keywords.join(', ')} />}
    {seo && <link rel="canonical" href={seo.canonical} />}
    <meta name="robots" content="index, follow" />
    {doctor && <meta name="author" content={`${doctor.titulo} ${doctor.nombre}`} />}
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    {seo && <meta property="og:url" content={seo.canonical} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {seo && <meta property="og:image" content={seo.ogImage} />}
    {seo && <meta property="og:locale" content={seo.locale} />}
    {seo && <meta property="og:site_name" content={seo.siteName} />}
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {seo && <meta name="twitter:image" content={seo.ogImage} />}
    
    <!-- Google Verification -->
    {seo?.googleVerification && (
      <meta name="google-site-verification" content={seo.googleVerification} />
    )}
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    
    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <!-- Fuentes -->
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Structured Data -->
    {config && seo && doctor && contacto && (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': seo.structuredData.type,
        name: `${doctor.titulo} ${doctor.nombre}`,
        description: seo.description,
        image: doctor.foto,
        telephone: contacto.telefono,
        email: contacto.email,
        url: seo.canonical,
        priceRange: seo.structuredData.priceRange,
        medicalSpecialty: seo.structuredData.medicalSpecialty,
        address: {
          '@type': 'PostalAddress',
          streetAddress: contacto.direccion,
          addressLocality: contacto.ciudad,
          addressRegion: contacto.estado,
          addressCountry: contacto.pais,
          postalCode: contacto.codigoPostal,
        },
        openingHoursSpecification: horarios.map((h) => ({
          '@type': 'OpeningHoursSpecification',
          dayOfWeek: h.dias,
          opens: h.horas.split(' - ')[0],
          closes: h.horas.split(' - ')[1],
        })),
        hasOfferCatalog: {
          '@type': 'OfferCatalog',
          name: 'Servicios Médicos',
          itemListElement: servicios.map((s) => ({
            '@type': 'Offer',
            itemOffered: {
              '@type': 'MedicalProcedure',
              name: s.nombre,
              description: s.descripcion,
            },
          })),
        },
      })} />
    )}

    <!-- Colores dinámicos -->
    <style define:vars={{
      colorPrimario: colores.primario,
      colorSecundario: colores.secundario,
    }}>
      :root {
        --color-primario: var(--colorPrimario);
        --color-secundario: var(--colorSecundario);
      }
    </style>
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
